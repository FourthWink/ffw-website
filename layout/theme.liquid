<style>
  :root {
    --ffw-hover-default-color: #666666;
    --ffw-hover-active-color: #000000;
    --ffw-hover-transition: color 0.3s ease, opacity 0.25s ease;
  }

  /* Global kerning reset */
  :where(
    h1, h2, h3, h4, h5, h6,
    p, span, a, button, input, textarea, select, option,
    label, small, strong, em, b, i, li, figcaption, summary,
    .button, .text-block, .custom-typography
  ) {
    letter-spacing: 0 !important;
  }

  /* Global interaction baseline for text controls (icons excluded) */
  :where(a, button, [role='button'], .button, input[type='submit'], input[type='button'], summary):not(:has(svg, img, .svg-wrapper, [class*='icon'])),
  :where(a, button, [role='button'], .button, input[type='submit'], input[type='button'], summary):not(:has(svg, img, .svg-wrapper, [class*='icon']))
    :where(span, strong, em, small, b, i, u, label, p, div):not(.visually-hidden) {
    color: var(--ffw-hover-default-color);
    transition: var(--ffw-hover-transition);
  }

  /* Global hover/focus/active color-only effect (no movement) */
  :where(a, button, [role='button'], .button, input[type='submit'], input[type='button'], summary):not(:has(svg, img, .svg-wrapper, [class*='icon'])):is(:hover, :focus-visible, :active),
  :where(a, button, [role='button'], .button, input[type='submit'], input[type='button'], summary):not(:has(svg, img, .svg-wrapper, [class*='icon'])):is(:hover, :focus-visible, :active)
    :where(span, strong, em, small, b, i, u, label, p, div):not(.visually-hidden) {
    color: var(--ffw-hover-active-color);
  }

  /* ==========================================================
     NAVBAR OVERRIDES
  ========================================================== */
  header-component .list-menu__item,
  header-component .list-menu__item span,
  header-component .header__menu-item,
  header-component .header__menu-item span,
  #header-group a,
  #header-group a span {
    color: #000000 !important;
    opacity: 1 !important;
    visibility: visible !important;
  }

  /* Only apply hover effects on devices with a real mouse/trackpad */
  @media (hover: hover) and (pointer: fine) {
    header-component .list-menu__item:hover,
    header-component .list-menu__item:hover span,
    header-component .header__menu-item:hover,
    header-component .header__menu-item:hover span,
    #header-group a:hover,
    #header-group a:hover span {
      color: #000000 !important;
      opacity: 1 !important;
      background-color: transparent !important;
    }
  }

  /* ==========================================================
     TOUCH DEVICE OPTIMIZATIONS & FORCED VISIBILITY
  ========================================================== */
  * {
    -webkit-tap-highlight-color: transparent;
  }
  .ffw-static-text, .center-star-bg, .wishlist-btn {
    -webkit-user-select: none;
    user-select: none;
  }

  @media (hover: none) {
    /* Force the wishlist or quick-add buttons to always show on mobile/tablet */
    [class*="ai-picks-grid-container-"] .wishlist-btn,
    [class*="ai-picks-grid-container-"] .quick-add {
      opacity: 1 !important;
      visibility: visible !important;
      transform: none !important;
      display: block !important;
    }
  }

  /* ==========================================================
     GLOBAL FOGS
  ========================================================== */
  .ffw-global-top-blur {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 90px;
    background: linear-gradient(
      to bottom,
      rgba(255, 255, 255, 1) 0%,
      rgba(255, 255, 255, 1) 55%,
      rgba(255, 255, 255, 0.98) 60%,
      rgba(255, 255, 255, 0.92) 65%,
      rgba(255, 255, 255, 0.82) 70%,
      rgba(255, 255, 255, 0.68) 75%,
      rgba(255, 255, 255, 0.50) 80%,
      rgba(255, 255, 255, 0.32) 85%,
      rgba(255, 255, 255, 0.16) 90%,
      rgba(255, 255, 255, 0.06) 95%,
      rgba(255, 255, 255, 0.02) 98%,
      rgba(255, 255, 255, 0) 100%
    );
    z-index: 585;
    pointer-events: none;
  }
/* Mobile Blur Heights */
  @media screen and (max-width: 768px) {
    .ffw-global-top-blur {
      height: 55px !important; /* Change this number to make it shorter/taller on mobile */
    }
    .ffw-global-bottom-blur {
      height: 35px !important;
    }
  }
  .ffw-global-bottom-blur {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 55px;
    background: linear-gradient(
      to top,
      rgba(255, 255, 255, 1) 0%,
      rgba(255, 255, 255, 1) 10%,
      rgba(255, 255, 255, 0.98) 15%,
      rgba(255, 255, 255, 0.95) 20%,
      rgba(255, 255, 255, 0.90) 25%,
      rgba(255, 255, 255, 0.84) 30%,
      rgba(255, 255, 255, 0.76) 35%,
      rgba(255, 255, 255, 0.68) 40%,
      rgba(255, 255, 255, 0.59) 45%,
      rgba(255, 255, 255, 0.50) 50%,
      rgba(255, 255, 255, 0.32) 60%,
      rgba(255, 255, 255, 0.17) 70%,
      rgba(255, 255, 255, 0.06) 80%,
      rgba(255, 255, 255, 0.01) 90%,
      rgba(255, 255, 255, 0) 100%
    );
    z-index: 585;
    pointer-events: none;
  }

  /* ==========================================================
     GLOBAL SCROLLBAR & OVERLAYS
  ========================================================== */
  html, body {
    scrollbar-width: none;
    -ms-overflow-style: none;
    position: relative !important;
  }
  html::-webkit-scrollbar,
  body::-webkit-scrollbar {
    display: none;
  }

  html:not([scroll-lock]) { overflow-y: auto !important; }
  body:not(.ffwinks-open):not(.ffwinks-body-lock):not(.vi-video-active) { overflow-y: auto !important; }
  body.ffwinks-open:not(:has(#ffwinks-search-bar.is-open, #ffwinks-account-bar.is-open)) { overflow-y: auto !important; }
  body.ffwinks-body-lock:not(:has(.ffwinks-fullscreen.ffwinks-fullscreen--open[aria-hidden='false'])) { overflow-y: auto !important; }
  body.vi-video-active:not(:has(.vi-intro-window.show)) { overflow-y: auto !important; }
  html[scroll-lock]:not(:has(details[scroll-lock][open])) { overflow-y: auto !important; }
  body:not(:has(#ffwinks-search-bar.is-open, #ffwinks-account-bar.is-open)) #ffwinks-global-overlay { opacity: 0 !important; pointer-events: none !important; }
  #ffwinks-search-bar[aria-hidden='true'], #ffwinks-account-bar[aria-hidden='true'] { opacity: 0 !important; visibility: hidden !important; pointer-events: none !important; }
  .ffwinks-fullscreen[aria-hidden='true'] { opacity: 0 !important; visibility: hidden !important; pointer-events: none !important; }
  body:not(.ffw-filter-open) #ffw-filter-view, body:not(.ffw-filter-open) #ffw-filter-backdrop { opacity: 0 !important; visibility: hidden !important; pointer-events: none !important; }

/* ==========================================================
     HIDE STAR AND TEXT ON SPECIFIC PAGES
  ========================================================== */
  body:has(main[data-template="page.about"]) .center-star-bg,
  body:has(main[data-template="page.contact"]) .center-star-bg,
  body:has(main[data-template="ffw-shop"]) .center-star-bg,
  body:has(main[data-template="ffw-newin"]) .center-star-bg,
  body:has(main[data-template="search"]) .center-star-bg,
  body:has(main[data-template="product"]) .center-star-bg,
  body:has(main[data-template="page.about"]) .ffw-static-text,
  body:has(main[data-template="page.contact"]) .ffw-static-text,
  body:has(main[data-template="ffw-shop"]) .ffw-static-text,
  body:has(main[data-template="ffw-newin"]) .ffw-static-text,
  body:has(main[data-template="search"]) .ffw-static-text,
  body:has(main[data-template="product"]) .ffw-static-text {
    display: none !important;
  }
/* ==========================================================
     HIDE STAR AND TEXT: CART & WISHLIST (SEAMLESS FADE)
  ========================================================== */
  
  /* 1. Base State: Fade back in smoothly when closing */
  .center-star-bg,
  .ffw-static-text {
    transition: opacity 0.35s ease, visibility 0s 0s !important; 
  }

  /* 2. Hidden State: Hyper-optimized class lookup instead of body:has() */
  body.ffwinks-open .center-star-bg,
  body.ffwinks-body-lock .center-star-bg,
  body.ffwinks-open .ffw-static-text,
  body.ffwinks-body-lock .ffw-static-text {
    opacity: 0 !important;
    visibility: hidden !important;
    transition: opacity 0.35s ease, visibility 0s 0.35s !important; 
  }
    /* ==========================================================
     HIDE STAR AND TEXT ON SPECIFIC PAGES
  ========================================================== */
  body:has(main[data-template="page.about"]) .center-star-bg,
  body:has(main[data-template="ffw-shop"]) .center-star-bg,
  body:has(main[data-template="ffw-newin"]) .center-star-bg,
  body:has(main[data-template="search"]) .center-star-bg,
  body:has(main[data-template="product"]) .center-star-bg,
  html.ffw-policy-page .center-star-bg,
  body.ffw-policy-page .center-star-bg,
  body:has(main[data-template="page.about"]) .ffw-static-text,
  body:has(main[data-template="ffw-shop"]) .ffw-static-text,
  body:has(main[data-template="ffw-newin"]) .ffw-static-text,
  body:has(main[data-template="search"]) .ffw-static-text,
  body:has(main[data-template="product"]) .ffw-static-text,
  html.ffw-policy-page .ffw-static-text,
  body.ffw-policy-page .ffw-static-text {
    display: none !important;
  }
  /* ==========================================================
     STAR & TEXT CSS (COMPLETELY UNCLICKABLE)
  ========================================================== */
  .center-star-bg {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 500 !important;
    pointer-events: none !important; 
    width: var(--star-w, 150px);
    mix-blend-mode: difference;
  }
  .center-star-bg img,
  .center-star-bg svg,
  .center-star-bg * {
    width: 150px;
    height: auto;
    display: block;
    pointer-events: none !important; 
  }
  .center-star-bg svg {
    fill: #ffffff !important;
    stroke: none !important;
  }

  .ffw-static-text {
    position: absolute !important;
    top: 50% !important; 
    left: 50% !important;
    transform: translate(-50%, -50%) !important;
    z-index: 1 !important;
    pointer-events: none !important;
    text-align: center !important;
    line-height: 1.2 !important;
    color: black !important;
    width: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  /* ==========================================================
     CART CHECKOUT BLEED FIX 
  ========================================================== */
  #ffwinks-cart-overlay[aria-hidden='true'] .ffwinks-soul-checkout-wrapper,
  #ffwinks-cart-overlay[aria-hidden='true'] a[href="/checkout"],
  #ffwinks-cart-overlay[aria-hidden='true'] a[href*="/checkout"] {
    display: none !important;
    pointer-events: none !important;
    visibility: hidden !important;
    width: 0 !important;
    height: 0 !important;
  }

  /* ==========================================================
     CART BUBBLE CSS
  ========================================================== */
  cart-count, .cart-count, .cart-count-bubble, [class*="CartCount"], [class*="cart_count"] {
    position: absolute !important; top: -8px !important; right: -8px !important; left: auto !important; bottom: auto !important; min-width: 14px !important; width: auto !important; height: 14px !important; padding: 0 3px !important; background: #222 !important; color: #fff !important; font-family: 'Montserrat', Arial, sans-serif !important; font-size: 7px !important; font-weight: 700 !important; letter-spacing: 0 !important; line-height: 14px !important; text-align: center !important; border-radius: 7px !important; box-sizing: border-box !important; pointer-events: none !important; z-index: 1 !important; clip-path: none !important; transform: none !important; margin: 0 !important;
  }
  .header-actions__action:has(cart-count),
  .header-actions__action:has(.cart-count),
  .header-actions__action:has(.cart-count-bubble) {
    position: relative !important;
    overflow: visible !important;
  }

  /* Homepage: keep native scrolling, no snap logic */
  body:has(main[data-template="index"]) #MainContent {
    position: relative !important;
    height: auto !important;
    overflow: visible !important;
    scroll-snap-type: none !important;
  }
  /* Hides all floating buttons when ANY Fourth Wink overlay is open */
  body.ffwinks-body-lock .floating-atc,
  body.ffwinks-body-lock #ffwinks-mobile-atc,
  body.ffwinks-body-lock #ffwinks-product-sparkle,
  body.ffwinks-open .floating-atc,
  body.ffwinks-open #ffwinks-mobile-atc,
  body.ffwinks-open #ffwinks-product-sparkle,
  body:has(#ffwinks-search-bar.is-open) .floating-atc,
  body:has(#ffwinks-search-bar.is-open) #ffwinks-mobile-atc,
  body:has(#ffwinks-search-bar.is-open) #ffwinks-product-sparkle {
    opacity: 0 !important;
    visibility: hidden !important;
    pointer-events: none !important;
    z-index: -1 !important;
  }

  /* Push center star behind search overlay when search is open */
  body:has(#ffwinks-search-bar.is-open) .center-star-bg {
    z-index: -1 !important;
  }
  /* ==========================================================
   PREORDER BADGE OVERRIDE
========================================================== */
.product-card[data-available-colors] .product-badges__badge {
  /* too broad — use tag approach below */
}
/* Rename Sale → Preorder for products tagged 'preorder' */
body .product-grid__item:has(product-card[data-tags~="preorder"]) .product-badges__badge::before {
