    <script>
      (function setHeaderHeighCustomProperties() {
        var header = document.querySelector('header-component');
        var headerGroup = document.querySelector('#header-group');
        if (!header || !headerGroup) return;
        var headerHeight = header.offsetHeight;
        var headerGroupHeight = 0;
        var children = headerGroup.children;
        for (var i = 0; i < children.length; i++) {
          var element = children[i];
          if (element === header || !(element instanceof HTMLElement)) continue;
          headerGroupHeight += element.offsetHeight;
        }
        document.body.style.setProperty('--header-height', headerHeight + 'px');
        document.body.style.setProperty('--header-group-height', headerGroupHeight + 'px');
      })();

      window.addEventListener('DOMContentLoaded', function() {
        if (navigator.platform.toUpperCase().indexOf('MAC') >= 0) {
          document.body.classList.add('is-mac');
        }

        var overlay = document.getElementById('intro-overlay');
        var eye = document.getElementById('eye');
        var text = document.getElementById('intro-text');

        function getCookie(name) {
          var found = document.cookie.split('; ').filter(function(row) {
            return row.startsWith(name + '=');
          });
          return found.length ? found[0].split('=')[1] : undefined;
        }
        function setCookie(name, value, days) {
          var expires = new Date(Date.now() + days * 864e5).toUTCString();
          document.cookie = name + '=' + value + '; expires=' + expires + '; path=/';
        }

        if (getCookie('intro_seen')) {
          if (overlay) overlay.style.display = 'none';
        } else if (eye) {
          if (overlay) overlay.style.display = 'flex';
          // =========================================================
          // INTRO OVERLAY REQUIRES CLICK ON THE EYE TO ENTER
          // =========================================================
          eye.addEventListener('click', function() {
            if(text) text.style.opacity = '0';
            if(eye) eye.style.transform = 'scale(2)';
            setTimeout(function() {
              if (overlay) overlay.style.opacity = '0';
              setTimeout(function() { if (overlay) overlay.style.display = 'none'; }, 800);
            }, 1000);
            setCookie('intro_seen', '1', 120);
          });
        }
      });

      // ==========================================================
      // STAR ANCHOR ENGINE (Continuous rAF Logic)
      // ==========================================================
      window.addEventListener('DOMContentLoaded', function() {
        var star = document.querySelector('.center-star-bg');
        if (!star) return;

        function init() {
          // Find the actual visible grid container to prevent locking onto hidden mobile clones
          var grids = document.querySelectorAll("[class*='ai-picks-grid-container']");
          var target = null;
          
          for (var i = 0; i < grids.length; i++) {
            if (grids[i].getBoundingClientRect().height > 50) { 
              target = grids[i];
              break;
            }
          }

          // If lazy-loaded sections haven't popped in yet, try again
          if (!target) {
            setTimeout(init, 300);
            return;
          }

          function applyState() {
            var rect = target.getBoundingClientRect();
            var targetMidInViewport = rect.top + rect.height / 2;
            var viewportMid = window.innerHeight / 2;

            if (targetMidInViewport <= viewportMid) {
              // Grid center is at or above viewport center — pin star to grid
              star.style.top = targetMidInViewport + 'px';
            } else {
              // Grid center is below viewport center — star follows viewport center
              star.style.top = '50%';
            }
          }

          // Always fixed, always running via requestAnimationFrame
          star.style.position = 'fixed';
          star.style.left = '50%';
          star.style.transform = 'translate(-50%, -50%)';

          function loop() {
            applyState();
            requestAnimationFrame(loop);
          }

          loop();
        }

        init();
      });

      window.addEventListener('DOMContentLoaded', function() {
        var isHomepage = document.querySelector('main[data-template="index"]');
        if (!isHomepage) return;

        var snapLockUntil = 0;
        var snapAnimationFrame = null;
        var touchStartY = null;

        function getScrollElement() {
          var scrollingElement = document.scrollingElement || document.documentElement;
          if (scrollingElement && scrollingElement.scrollHeight > scrollingElement.clientHeight + 1) return scrollingElement;
          if (document.body && document.body.scrollHeight > document.body.clientHeight + 1) return document.body;
          return scrollingElement;
        }

        function getScrollTop() {
          var scrollElement = getScrollElement();
          if (scrollElement === document.body) return document.body.scrollTop;
          return window.scrollY || (scrollElement ? scrollElement.scrollTop : 0);
        }

        function scrollToPosition(target) {
          var scrollElement = getScrollElement();
          var start = getScrollTop();
          var distance = target - start;
          var duration = 1100;
          var startTime = performance.now();

          if (snapAnimationFrame) cancelAnimationFrame(snapAnimationFrame);

          function setScrollTop(value) {
            if (scrollElement === document.body) {
              document.body.scrollTop = value;
            } else {
              window.scrollTo(0, value);
            }
          }

          function step(now) {
            var progress = Math.min((now - startTime) / duration, 1);
            var eased = 1 - Math.pow(1 - progress, 3);
            setScrollTop(start + (distance * eased));
            if (progress < 1) {
              snapAnimationFrame = requestAnimationFrame(step);
            } else {
              snapAnimationFrame = null;
            }
          }

          snapAnimationFrame = requestAnimationFrame(step);
        }

        function getDreamPicksTarget() {
          var grids = document.querySelectorAll("[class*='ai-picks-grid-container']");
          for (var i = 0; i < grids.length; i++) {
            var rect = grids[i].getBoundingClientRect();
            if (rect.height > 50) {
              return Math.max(0, getScrollTop() + rect.top + (rect.height / 2) - (window.innerHeight / 2));
            }
          }
          return null;
        }

        function snapToDreamPicks() {
          var target = getDreamPicksTarget();
          if (target === null) return;
          snapLockUntil = Date.now() + 1200;
          scrollToPosition(target);
        }

        function shouldSnapDown() {
          var target = getDreamPicksTarget();
          return target !== null && getScrollTop() < target - 4;
        }

        function hasBlockingOverlay() {
          return document.body.classList.contains('ffwinks-open') ||
            document.body.classList.contains('ffwinks-body-lock') ||
            document.querySelector('.ffwinks-fullscreen.ffwinks-fullscreen--open');
        }

        window.addEventListener('wheel', function(event) {
          if (hasBlockingOverlay()) return;
          if (event.deltaY <= 0) return;
          if (Date.now() < snapLockUntil) {
            event.preventDefault();
            return;
          }
          if (shouldSnapDown()) {
            event.preventDefault();
            snapToDreamPicks();
          }
        }, { passive: false });

        window.addEventListener('touchstart', function(event) {
          touchStartY = event.touches && event.touches[0] ? event.touches[0].clientY : null;
        }, { passive: true });

        window.addEventListener('touchmove', function(event) {
          if (hasBlockingOverlay()) return;
          if (touchStartY === null || !event.touches || !event.touches[0]) return;
          var isScrollingDown = touchStartY - event.touches[0].clientY > 8;
          if (!isScrollingDown) return;
          if (Date.now() < snapLockUntil) {
            event.preventDefault();
            return;
          }
          if (shouldSnapDown()) {
            event.preventDefault();
            snapToDreamPicks();
          }
        }, { passive: false });
      });

      function clearStaleScrollLocks() {
        var searchBar      = document.getElementById('ffwinks-search-bar');
        var accountBar     = document.getElementById('ffwinks-account-bar');
        var globalOverlay  = document.getElementById('ffwinks-global-overlay');
        var wishlistOverlay = document.getElementById('ffwinks-wishlist-overlay');
        var cartOverlay    = document.getElementById('ffwinks-cart-overlay');
        var filterView     = document.getElementById('ffw-filter-view');
        var filterBackdrop = document.getElementById('ffw-filter-backdrop');
        var visibleVideoIntro = Array.from(document.querySelectorAll('.vi-intro-window.show')).some(function(el) {
          return el instanceof HTMLElement && el.style.display !== 'none';
        });
        
        if (searchBar)    { searchBar.classList.remove('is-open'); searchBar.setAttribute('aria-hidden', 'true'); }
        if (accountBar)   { accountBar.classList.remove('is-open'); accountBar.setAttribute('aria-hidden', 'true'); }
        if (globalOverlay){ globalOverlay.classList.remove('is-active'); }
        [wishlistOverlay, cartOverlay].forEach(function(ov) {
          if (!ov) return;
          ov.classList.remove('ffwinks-fullscreen--open');
          ov.setAttribute('aria-hidden', 'true');
        });
        if (filterView)     { filterView.classList.remove('ffw-show'); }
        if (filterBackdrop) { filterBackdrop.classList.remove('ffw-show'); }
        document.body.classList.remove('ffwinks-open', 'ffwinks-body-lock', 'ffw-filter-open');
        if (!visibleVideoIntro) { document.body.classList.remove('vi-video-active'); }
        var hasLockedDetails = document.querySelector('details[scroll-lock][open]');
        if (!hasLockedDetails) { document.documentElement.removeAttribute('scroll-lock'); }

        var isHomepage = document.querySelector('main[data-template="index"]');
        if (!isHomepage) {
          document.documentElement.style.overflow = '';
          document.documentElement.style.overflowY = '';
          document.body.style.overflow = '';
          document.body.style.overflowY = '';
        }
      }

      window.addEventListener('DOMContentLoaded', clearStaleScrollLocks);
      window.addEventListener('pageshow', clearStaleScrollLocks);
      window.addEventListener('load', clearStaleScrollLocks);

      (function hideStarOnSpecificPages() {
        var path = window.location.pathname;
        if (
          path.indexOf('/collections/shop') !== -1 ||
          path.indexOf('/collections/new-in') !== -1 ||
          path.indexOf('ffw-shop') !== -1 ||
          path.indexOf('ffw-newin') !== -1
        ) {
          var star = document.querySelector('.center-star-bg');
          var text = document.querySelector('.ffw-static-text');
          if (star) star.style.display = 'none';
          if (text) text.style.display = 'none';
        }
      })();
    </script>
    {% render 'intro-overlay' %}
    {% section 'ffw-filter' %}
  </body>
</html>
