{% comment %}
  Fourth Wink legacy cart overlay styles.

  JavaScript remains in sections/custom-liquid.liquid while the legacy cart
  overlay is being separated from the generic Custom Liquid section wrapper.
{% endcomment %}

<style>
  :root {
    --cart-header-h: 54px; 
    --cart-pad-x: 30px; 
    --cart-img-h: clamp(150px, calc(52vh - var(--cart-header-h) - 20px), 420px);
    --cart-items-padding-bottom: 32vh;
  }

  /* --- Huge Screens (1800px+) --- */
  @media screen and (min-width: 1800px) {
    :root {
      --cart-img-h: clamp(350px, calc(51vh - var(--cart-header-h) - 20px), 800px);
    }
  }

  /* 1. Global Reset - Set to 500 so it sits neatly UNDER the Header (z-index 600) */
  .cart-overlay { display: none; position: fixed; inset: 0; z-index: 500; font-family: var(--cart-font); }
  .cart-overlay.is-open { display: block; }
  .cart-overlay__backdrop { position: absolute; inset: 0; background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(4px); animation: backdropIn 0.25s ease forwards; }

  @keyframes backdropIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes backdropOut { from { opacity: 1; } to { opacity: 0; } }
  @keyframes drawerIn { from { transform: translateX(100%); } to { transform: translateX(0); } }
  @keyframes drawerOut { from { transform: translateX(0); } to { transform: translateX(100%); } }

  /* 2. Desktop-Only CSS (Side Drawer) */
  @media screen and (min-width: 750px) {
    .mobile-only { display: none !important; }
    
    .cart-overlay__drawer {
      position: absolute; top: 0; right: 0; bottom: 0; width: 50vw;
      background: var(--cart-bg); display: flex; flex-direction: column;
      border-left: 1px solid #eee;
      animation: drawerIn 0.3s cubic-bezier(0.32, 0.72, 0, 1) forwards;
    }
    .cart-overlay.is-closing .cart-overlay__drawer { animation: drawerOut 0.25s cubic-bezier(0.32, 0.72, 0, 1) forwards; }
    .cart-overlay.is-closing .cart-overlay__backdrop { animation: backdropOut 0.25s ease forwards; }

    .cart-overlay__header { display: flex; justify-content: flex-end; align-items: center; padding: 0 var(--cart-pad-x); height: var(--cart-header-h); flex-shrink: 0; }
    .cart-overlay__close { background: none; border: none; cursor: pointer; padding: 10px; display: flex; align-items: center; justify-content: center; transition: opacity 0.2s; }
    .cart-overlay__close:hover { opacity: 0.6; }

    .cart-overlay__floating-wrapper {
      position: fixed;
      top: 50%;
      left: 50vw;
      transform: translate(-50%, -50%);
      z-index: 505;
      transition: top 0.15s ease-out;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      mix-blend-mode: normal;
      view-transition-name: none !important;
    }
    body.cart-overlay-open .cart-overlay__floating-wrapper { 
      opacity: 1 !important; 
      visibility: visible !important; 
      pointer-events: auto !important; 
    }
    .ffwinks-img-btn-wrap { color: #ffffff; }
    .cart-overlay__floating-svg { filter: brightness(0); }

    .cart-overlay__items { 
      flex: 1 1 auto; 
      overflow-y: auto; 
      padding: 0 var(--cart-pad-x) 0 var(--cart-pad-x); 
      scrollbar-width: none; 
      -ms-overflow-style: none;
      padding-bottom: var(--cart-items-padding-bottom);
    }
    .cart-overlay__items::-webkit-scrollbar { display: none; }

    .cart-item { position: relative; display: flex; flex-direction: column; width: calc(100% + var(--cart-pad-x)); margin-left: -25px; margin-bottom: 40px;
      animation: itemFadeIn 0.3s ease forwards; opacity: 0; }
    .cart-item__remove-btn-desktop { position: absolute; top: 10px; left: 5px; background: transparent; border: none; font-size: 18px; color: #666; cursor: pointer; z-index: 5; padding: 0; line-height: 1; font-family: 'Montserrat', Arial, sans-serif !important; transition: color 0.2s, font-weight 0.1s; }
    .cart-item__remove-btn-desktop:hover { color: #000; }
    
    .cart-item__left { width: 100%; height: var(--cart-img-h); background: #f4f4f4; border-radius: 70px; display: flex; justify-content: center; align-items: center; overflow: hidden; transform: translateZ(0); }
    .cart-item__left img { width: 50%; height: 100%; object-fit: contain; object-position: center; pointer-events: none; transition: none; will-change: auto; }
    
    .cart-item__right { display: flex; flex-direction: column; padding: 30px 10px 10px 20px; gap: 16px; font-size: 9px; color: var(--cart-text-color); }
    .cart-item__row { display: flex; justify-content: space-between; align-items: center; font-size: 10px; margin-bottom: 10px; }
    .cart-item__title, .cart-item__price { font-weight: 500; }
    .cart-item__variant-row, .cart-item__qty-container { display: flex; justify-content: flex-start; align-items: center; }
    .cart-item__variant-label, .cart-item__qty-label { width: 100px; color: var(--cart-text-color); font-weight: 400; }
    .cart-item__qty { display: flex; align-items: center; gap: 20px; }
    .cart-item__qty-btn { background: none; border: none; cursor: pointer; font-size: 10px; color: var(--cart-text-color); padding: 0; line-height: 1; }
    .cart-item__qty-num { min-width: 12px; text-align: center; }

    .cart-overlay__footer { flex-shrink: 0; background: var(--cart-footer-bg); padding: 30px 40px; border-radius: 40px 40px 0 0; margin: 0 10px; }
    .cart-overlay__subtotal-row { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px; font-size: 10px; }
    .cart-overlay__subtotal-label { color: var(--cart-text-color); }
    .cart-overlay__subtotal-value { color: var(--cart-text-color); font-weight: bold; }
    .cart-overlay__tax-note { font-size: 9px; color: var(--cart-muted-color); margin: 0; }
  }

  /* 3. Mobile-Only CSS (Soul Style) */
  @media screen and (max-width: 749px) {
    .desktop-only { display: none !important; }
    
    .mobile-ffwinks-cart {
      position: fixed; inset: 0; width: 100vw; height: 100dvh;
      background: #fff; z-index: 501;
      animation: drawerIn 0.3s cubic-bezier(0.32, 0.72, 0, 1) forwards;
    }
    .cart-overlay.is-closing .mobile-ffwinks-cart { animation: drawerOut 0.25s cubic-bezier(0.32, 0.72, 0, 1) forwards; }
    .cart-overlay.is-closing .cart-overlay__backdrop { animation: backdropOut 0.25s ease forwards; }

    .mobile-scrollable-area {
      position: absolute; inset: 0;
      overflow-y: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding-top: var(--header-overlay-offset, 60px);
      padding-bottom: 7svh; 
      z-index: 1;
    }
    .mobile-scrollable-area::-webkit-scrollbar { display: none; }

    .ffwinks-soul-list { 
      padding: var(--soul-list-pt, 40px) var(--ffwinks-master-spacing, 30px) 0 0;
    }

    .ffwinks-soul-subtotal-wrapper {
      position: fixed; bottom: 0; left: 0; right: 0;
      z-index: 504; 
      text-align: right; width: 100%;
      padding-right: 30px;
      padding-top: var(--soul-subtotal-pt-cart, 48px);
      padding-bottom: 20px;
      background: linear-gradient(to top, rgba(255,255,255,1) 35%, rgba(255,255,255,0) 100%);
      box-sizing: border-box;
      pointer-events: none;
    }
    .ffwinks-soul-subtotal-row,
    .ffwinks-soul-subtotal-info { pointer-events: auto; }
    .ffwinks-soul-subtotal-row { display: flex; justify-content: flex-end; gap: 38px; margin-bottom: 8px; }
    .ffwinks-soul-subtotal-label { font-size: 10px; color: #333; font-weight: bold; }
    .ffwinks-soul-subtotal-price { font-size: 10px; color: #333; font-weight: normal; }
    .ffwinks-soul-subtotal-info { font-size: 9px; color: #bbb; margin: 0; text-align: right; }

    .ffwinks-soul-checkout-wrapper {
      position: fixed !important; left: 50% !important;
      top: 50% !important;
      transform: translate3d(-50%, -50%, 0) !important;
      z-index: 505;
      pointer-events: none;
      display: flex; justify-content: center;
      align-items: center;
    }
    .ffwinks-soul-action-bottom { pointer-events: auto; display: block; text-decoration: none; background: transparent; border: none; padding: 0; cursor: pointer; }
    .ffwinks-img-btn-wrap { position: relative; display: inline-block; line-height: 0; color: #666; }
    .ffwinks-action-img { width: 150px; height: auto; display: block; }
    .ffwinks-img-label { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 10px; color: #666; pointer-events: none; font-weight: 400; font-family: 'Montserrat', Arial, sans-serif !important; transition: color 0.3s ease; }
    .ffwinks-soul-action-bottom:hover .ffwinks-img-label { color: #000; }

    /* Mobile close button */
    .mobile-cart-close-btn {
      position: fixed; top: 50px;
      right: 16px;
      z-index: 506;
      background: rgba(255,255,255,0.9);
      border: 1px solid #e0e0e0;
      border-radius: 50%;
      width: 20px;
      height: 20px;
      display: flex; align-items: center;
      justify-content: center;
      cursor: pointer;
      backdrop-filter: blur(4px);
      transition: background 0.2s, opacity 0.2s;
    }
    .mobile-cart-close-btn:hover { background: #f0f0f0; }

    .mobile-star { filter: brightness(0); }

    /* Gradients to match homepage fog */
    .mobile-gradient-top { position: fixed; top: 0; left: 0; width: 100%; height: 40px; z-index: 5; pointer-events: none; background: linear-gradient(to bottom, rgba(255,255,255,1) 0%, rgba(255,255,255,0) 100%); }
    .mobile-gradient-bottom { position: fixed; bottom: 0; left: 0; width: 100%; height: 15px; z-index: 5; pointer-events: none; background: linear-gradient(to top, rgba(255,255,255,1) 0%, rgba(255,255,255,0) 100%); }
    
    .mobile-item {
      animation: itemFadeIn 0.3s ease forwards; opacity: 0;
    }
  }

  @keyframes itemFadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  body.cart-overlay-open { overflow: hidden; }

  /* Hide product page sparkle AND Add-to-Cart star when cart is open */
  body.cart-overlay-open #ffwinks-product-sparkle,
  body.cart-overlay-open .product-sparkle-icon,
  body.cart-overlay-open .floating-atc-btn,
  body.cart-overlay-open .floating-atc-wrapper {
    opacity: 0 !important; visibility: hidden !important;
    pointer-events: none !important;
  }

  /* Nuke ALL stars AND sparkles off the screen the second the Lips transition starts */
  body:has(#ffw-checkout-transition.is-active) #ffwinks-product-sparkle,
  body:has(#ffw-checkout-transition.is-active) .product-sparkle-icon,
  body:has(#ffw-checkout-transition.is-active) .floating-atc-btn,
  body:has(#ffw-checkout-transition.is-active) .cart-overlay__floating-wrapper,
  body:has(#ffw-checkout-transition.is-active) .ffwinks-soul-checkout-wrapper {
    opacity: 0 !important; visibility: hidden !important;
    pointer-events: none !important;
  }
  .cart-overlay__loading, .ffwinks-empty-msg { text-align: center; color: #ccc; font-size: 9px; margin-top: 50px; font-family: 'Montserrat', Arial, sans-serif !important; }
</style>
