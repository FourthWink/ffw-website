{% comment %}
  Fourth Wink legacy cart overlay markup.

  CSS and JavaScript remain in sections/custom-liquid.liquid while this markup
  is being separated from the generic Custom Liquid section wrapper.
{% endcomment %}

{% comment %}
  Desktop checkout star for the legacy cart overlay. Its position is adjusted
  from the script below so it can float near the active cart item.
{% endcomment %}
<div class="cart-overlay__floating-wrapper desktop-only" id="cart-checkout-wrapper-desktop">
  <a href="/checkout" class="ffwinks-soul-action-bottom cart-overlay__floating-btn" aria-label="Checkout">
    <div class="ffwinks-img-btn-wrap">
      <img src="{{ 'soul.svg' | asset_url }}" alt="Star" class="ffwinks-action-img cart-overlay__floating-svg">
      <span class="ffwinks-img-label cart-overlay__text">Checkout</span>
    </div>
  </a>
</div>

{% comment %}
  Legacy cart overlay markup. The newer FFWinks fullscreen cart also exists in
  snippets/ffwinks-cart.liquid; keep both systems separate when refactoring.
{% endcomment %}
<div id="cart-overlay" class="cart-overlay" aria-hidden="true">
  <div class="cart-overlay__backdrop" id="cart-backdrop"></div>

  <div class="cart-overlay__drawer desktop-only" role="dialog" aria-modal="true" aria-label="Your cart">

    <div class="cart-overlay__header">
      <button class="cart-overlay__close" id="cart-close-desktop" aria-label="Close cart">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M1 1L13 13M13 1L1 13" stroke="#000" stroke-width="1" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
    <div class="cart-overlay__items" id="cart-items-desktop">
      <div class="cart-overlay__loading">Loading cart…</div>
    </div>
    <div class="cart-overlay__footer">
      <div class="cart-overlay__subtotal-row">

        <span>Subtotal</span>
        <span id="cart-subtotal-desktop">—</span>
      </div>
      <p class="cart-overlay__tax-note">Shipping and taxes calculated at checkout</p>
    </div>
  </div>

  <div class="mobile-ffwinks-cart mobile-only">
    <div class="mobile-gradient-top"></div>
    <div class="mobile-gradient-bottom"></div>

    <button class="mobile-cart-close-btn" id="cart-close-mobile" aria-label="Close cart">
      <svg width="16" height="16" viewBox="0 0 14 14" fill="none">
        <path d="M1 1L13 13M13 1L1 13" stroke="#000" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <div class="ffwinks-soul-subtotal-wrapper">

      <div class="ffwinks-soul-subtotal-row">
        <span class="ffwinks-soul-subtotal-label">Subtotal</span>
        <span class="ffwinks-soul-subtotal-price" id="cart-subtotal-mobile">—</span>
      </div>
      <p class="ffwinks-soul-subtotal-info" id="cart-overlay-tax-note-mobile">Shipping and taxes calculated at checkout</p>
    </div>

    <div class="ffwinks-soul-checkout-wrapper" id="cart-checkout-wrapper-mobile">
      <a href="/checkout" class="ffwinks-soul-action-bottom" aria-label="Checkout">
        <div class="ffwinks-img-btn-wrap">
          <img src="{{ 'soul.svg' | asset_url }}" alt="Star" class="ffwinks-action-img mobile-star">
          <span class="ffwinks-img-label">Checkout</span>
        </div>
      </a>
    </div>

    <div class="mobile-scrollable-area">
      <div class="ffwinks-soul-list" id="cart-items-mobile">
        <div class="ffwinks-empty-msg">Loading cart…</div>
      </div>
    </div>
  </div>
</div>
