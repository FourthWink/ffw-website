{% comment %}
  FFWinks — Account Island
  Slide-down sign-in / register panel that appears below the header.
  Triggered by any a[href*="/account"] or a[href*="/login"] click.
  JS lives in ffwinks-js.liquid.
{% endcomment %}

<div id="ffwinks-account-bar" aria-hidden="true">
  <div class="ffwinks-island-section">
    <div class="ffwinks-island">
      <div class="ffwinks-container" style="display: flex; justify-content: center; padding: 30px 15px;">
        
        <div class="account-box" style="width: 100%; max-width: 400px; text-align: center;">
          <h2 class="account-title">Account</h2>
          <p style="margin-bottom: 20px; font-size: 9px; line-height: 1.5; opacity: 0.8;">
            We use a secure, passwordless system. Enter your email on the next page to log in or create a new account with a 6-digit code.
          </p>
        </div>
        
      </div>
    </div>
  </div>
</div>
