<script src="{{ 'header.js' | asset_url }}" type="module"></script>

<script>
(function () {
  'use strict';

  var header      = document.getElementById('header-component');
  var overlay     = document.getElementById('ffwinks-global-overlay');
  var searchBar   = document.getElementById('ffwinks-search-bar');
  var accountBar  = document.getElementById('ffwinks-account-bar');
  var searchInput = document.getElementById('ffwinks-search-input');

  var wishlistOverlay = document.getElementById('ffwinks-wishlist-overlay');
  var cartOverlay     = document.getElementById('ffwinks-cart-overlay');

  // ==========================================
  // FIXED STAR SCROLL LOGIC
  // ==========================================
  function ffwinksUpdateStar() {
    var openOverlay = document.querySelector('.ffwinks-fullscreen.ffwinks-fullscreen--open');
    var isOverlay = !!openOverlay;
    var activeList = null;
    var contextNode = document;

    if (isOverlay) {
      activeList = openOverlay.querySelector('.ffwinks-soul-list');
      contextNode = openOverlay;
    } else {
      var allLists = document.querySelectorAll('.ffwinks-soul-list');
      for (var i = 0; i < allLists.length; i++) {
        if (!allLists[i].closest('.ffwinks-fullscreen')) {
          activeList = allLists[i];
          break;
        }
      }
    }

    if (!activeList) return;

    var STAR_Z_INDEX = '1';
    
    // 🛒 CART SETTINGS
    var CART_DESK_0_ITEMS_TOP_PX = 349;       
    var CART_DESK_1_ITEM_TOP_PX = 350;        
    var CART_DESK_NUDGE_RIGHT = 5;            
    var CART_DESK_NUDGE_DOWN = 1;             

    // -- Huge Screens (1800px+)
    var CART_HUGE_0_ITEMS_TOP_PX = 655;       
    var CART_HUGE_1_ITEM_TOP_PX = 715; 

    var CART_SHORT_0_ITEMS_TOP_PX = 200;      
    var CART_SHORT_1_ITEM_TOP_PX = 250;       
    
    // -- Mobile (Keeps static float setting to ensure stability)
    var CART_MOB_0_ITEMS_TOP_PX = 345;        
    var CART_MOB_1_ITEM_TOP_PX = 345;       
    var CART_MOB_3_PLUS_FLOAT_PX = 345;       
    var CART_MOB_NUDGE_RIGHT = 6;          
    var CART_MOB_NUDGE_DOWN = 1;            

    // ✨ WISHLIST SETTINGS
    var WISH_DESK_0_ITEMS_TOP_PX = 289;      
    var WISH_DESK_1_ITEM_TOP_PX = 345;       
    var WISH_DESK_NUDGE_RIGHT = 6;         
    var WISH_DESK_NUDGE_DOWN = 1;         
    var WISH_DESK_2_ITEM_NUDGE = 1;        

    // -- Huge Screens (1800px+)
    var WISH_HUGE_0_ITEMS_TOP_PX = 655;      
    var WISH_HUGE_1_ITEM_TOP_PX = 715; 

    var WISH_SHORT_0_ITEMS_TOP_PX = 200;      
    var WISH_SHORT_1_ITEM_TOP_PX = 250;       
    
    // -- Mobile (Keeps static float setting to ensure stability)
    var WISH_MOB_0_ITEMS_TOP_PX = 286;        
    var WISH_MOB_1_ITEM_TOP_PX = 345;       
    var WISH_MOB_3_PLUS_FLOAT_PX = 345;       
    var WISH_MOB_NUDGE_RIGHT = 6;          
    var WISH_MOB_NUDGE_DOWN = 1;         
    var WISH_MOB_2_ITEM_NUDGE = 1;         
    
    var isMobile = window.innerWidth <= 549;
    var isShortScreen = !isMobile && window.innerHeight < 600; 
    var isHugeScreen = window.innerWidth >= 1800;
    var isTallCardLayout = !isMobile && (isHugeScreen || (window.innerWidth >= 1400 && window.innerHeight >= 820));
    
    var allStars = contextNode.querySelectorAll('.ffwinks-soul-checkout-wrapper, .ffwinks-soul-addall-wrapper');
    var star = null;
    var emptyStar = null;
    var isCart = false;

    allStars.forEach(function(s) {
      if (!isOverlay && s.closest('.ffwinks-fullscreen')) return; 
      
      if (s.id.indexOf('-empty') !== -1) {
        emptyStar = s;
      } else if (!star) {
        star = s;
      } else {
        s.style.display = 'none'; 
      }
    });

    var refStar = star || emptyStar;
    if (refStar) {
      isCart = refStar.classList.contains('ffwinks-soul-checkout-wrapper') || refStar.id.indexOf('cart') !== -1;
    }

    var px_0_items, px_1_item, nudge_x, nudge_y, nudge_2_item;

    if (isMobile) {
      px_0_items   = isCart ? CART_MOB_0_ITEMS_TOP_PX : WISH_MOB_0_ITEMS_TOP_PX;
      px_1_item    = isCart ? CART_MOB_1_ITEM_TOP_PX : WISH_MOB_1_ITEM_TOP_PX;
      nudge_x      = isCart ? CART_MOB_NUDGE_RIGHT : WISH_MOB_NUDGE_RIGHT;
      nudge_y      = isCart ? CART_MOB_NUDGE_DOWN : WISH_MOB_NUDGE_DOWN;
      nudge_2_item = isCart ? 0 : WISH_MOB_2_ITEM_NUDGE;
    } else if (isShortScreen) {
      px_0_items   = isCart ? CART_SHORT_0_ITEMS_TOP_PX : WISH_SHORT_0_ITEMS_TOP_PX;
      px_1_item    = isCart ? CART_SHORT_1_ITEM_TOP_PX : WISH_SHORT_1_ITEM_TOP_PX;
      nudge_x      = isCart ? CART_DESK_NUDGE_RIGHT : WISH_DESK_NUDGE_RIGHT;
      nudge_y      = isCart ? CART_DESK_NUDGE_DOWN : WISH_DESK_NUDGE_DOWN;
      nudge_2_item = isCart ? 0 : WISH_DESK_2_ITEM_NUDGE;
    } else if (isHugeScreen) {
      px_0_items   = isCart ? CART_HUGE_0_ITEMS_TOP_PX : WISH_HUGE_0_ITEMS_TOP_PX;
      px_1_item    = isCart ? CART_HUGE_1_ITEM_TOP_PX : WISH_HUGE_1_ITEM_TOP_PX;
      nudge_x      = isCart ? CART_DESK_NUDGE_RIGHT : WISH_DESK_NUDGE_RIGHT;
      nudge_y      = isCart ? CART_DESK_NUDGE_DOWN : WISH_DESK_NUDGE_DOWN;
      nudge_2_item = isCart ? 0 : WISH_DESK_2_ITEM_NUDGE;
    } else {
      px_0_items   = isCart ? CART_DESK_0_ITEMS_TOP_PX : WISH_DESK_0_ITEMS_TOP_PX;
      px_1_item    = isCart ? CART_DESK_1_ITEM_TOP_PX : WISH_DESK_1_ITEM_TOP_PX;
      nudge_x      = isCart ? CART_DESK_NUDGE_RIGHT : WISH_DESK_NUDGE_RIGHT;
      nudge_y      = isCart ? CART_DESK_NUDGE_DOWN : WISH_DESK_NUDGE_DOWN;
      nudge_2_item = isCart ? 0 : WISH_DESK_2_ITEM_NUDGE;
    }

    // ── Restored from V1 (correct desktop values) ──────────────────────────
    var CART_TALL_SINGLE_ITEM_MIN_NUDGE_Y = 60;
    var CART_TALL_SINGLE_ITEM_MAX_NUDGE_Y = 145;
    var CART_TALL_SINGLE_ITEM_NUDGE_Y = 175;
    var CART_CENTER_NUDGE_Y = -26;
    var CART_SINGLE_ITEM_NUDGE_Y = 130;
    var WISH_CENTER_NUDGE_Y = -46;
    // ───────────────────────────────────────────────────────────────────────

    function ffwinksGetCartTallSingleItemNudgeY() {
      if (!isTallCardLayout) return 0;

      var minTallHeight = 820;
      var maxTallHeight = 2160; 
      var viewportHeight = window.innerHeight;
      var progress = (viewportHeight - minTallHeight) / (maxTallHeight - minTallHeight);

      if (progress < 0) progress = 0;
      if (progress > 1) progress = 1;

      return Math.round(
        CART_TALL_SINGLE_ITEM_MIN_NUDGE_Y +
        ((CART_TALL_SINGLE_ITEM_MAX_NUDGE_Y - CART_TALL_SINGLE_ITEM_MIN_NUDGE_Y) * progress)
      );
    }

    function ffwinksGetCenteredStarTop() {
      var viewport = window.visualViewport;
      var viewportTop = viewport ? viewport.offsetTop : 0;
      var viewportHeight = viewport ? viewport.height : window.innerHeight;
      var topBound = viewportTop;
      var bottomBound = viewportTop + viewportHeight;
      var centerNudgeY = isCart ? CART_CENTER_NUDGE_Y : WISH_CENTER_NUDGE_Y;

      if (isOverlay && openOverlay) {
        var overlayStyle = window.getComputedStyle(openOverlay);
        topBound = Math.max(topBound, viewportTop + (parseFloat(overlayStyle.paddingTop) || 0));
      }

      var wishlistHeader = contextNode.querySelector('.ffwinks-fullscreen__wishlist-header');
      if (wishlistHeader && (!wishlistHeader.closest('.ffwinks-fullscreen') || isOverlay)) {
        topBound = Math.max(topBound, wishlistHeader.getBoundingClientRect().bottom);
      }

      var footer = contextNode.querySelector('.ffwinks-soul-subtotal-wrapper');
      if (!isOverlay && footer && footer.closest('.ffwinks-fullscreen')) footer = null;
      if (footer && window.getComputedStyle(footer).display !== 'none') {
        bottomBound = Math.min(bottomBound, footer.getBoundingClientRect().top);
      }

      if (bottomBound <= topBound) {
        return (viewportTop + (viewportHeight / 2) + centerNudgeY) + 'px';
      }

      return (topBound + ((bottomBound - topBound) / 2) + centerNudgeY) + 'px';
    }

    function ffwinksCenterStar(el) {
      if (!el) return;

      el.style.setProperty('position', 'fixed', 'important');
      el.style.setProperty('left', '50%', 'important');
      el.style.setProperty('right', 'auto', 'important');
      el.style.setProperty('bottom', 'auto', 'important');
      el.style.setProperty('top', ffwinksGetCenteredStarTop(), 'important');
      el.style.setProperty('margin', '0', 'important');
      el.style.setProperty('transform', 'translate(-50%, -50%)', 'important');
      el.style.setProperty('z-index', STAR_Z_INDEX, 'important');
    }

    if (emptyStar) {
      ffwinksCenterStar(emptyStar);
    }

    if (!star) return;

    var rows = [];
    var allRows = contextNode.querySelectorAll('.ffwinks-soul-row');
    allRows.forEach(function(r) {
      if (!isOverlay && r.closest('.ffwinks-fullscreen')) return;
      rows.push(r);
    });

    // --- Disable scroll if 2 or fewer items exist ---
    if (isOverlay) {
      openOverlay.style.overflowY = (rows.length <= 2) ? 'hidden' : '';
    }

    if (rows.length === 0) {
      if (emptyStar) emptyStar.style.setProperty('display', 'flex', 'important');
      star.style.display = 'none';
      return;
    } else {
      if (emptyStar) emptyStar.style.setProperty('display', 'none', 'important');
      star.style.display = 'flex';
    }

    // --- DYNAMIC FLOAT HEIGHT (FIRST GAP) ---
    var baseFloatY = px_1_item;
    // Anchor the top limit to the first image so it doesn't float too high on small MacBooks
    var firstImg = rows[0] ? rows[0].querySelector('.ffwinks-soul-img-box') : null;
    if (firstImg) {
      baseFloatY = firstImg.getBoundingClientRect().top + (firstImg.getBoundingClientRect().height / 2);
    }
    if (rows.length >= 2) {
      if (isMobile) {
        var firstGapY = (rows[0].getBoundingClientRect().bottom + rows[1].getBoundingClientRect().top) / 2;
        var currentScroll = isOverlay ? openOverlay.scrollTop : window.scrollY;
        baseFloatY = firstGapY + currentScroll + nudge_y;
      } else {
        var imgFirst1 = rows[0].querySelector('.ffwinks-soul-img-box');
        var imgFirst2 = rows[1].querySelector('.ffwinks-soul-img-box');
        if (imgFirst1 && imgFirst2) {
          var firstGapY = (imgFirst1.getBoundingClientRect().bottom + imgFirst2.getBoundingClientRect().top) / 2;
          var currentScroll = isOverlay ? openOverlay.scrollTop : window.scrollY;
          baseFloatY = firstGapY + currentScroll + nudge_y;
        }
      }
    }

    var footer = contextNode.querySelector('.ffwinks-soul-subtotal-wrapper');
    if (!isOverlay && footer && footer.closest('.ffwinks-fullscreen')) footer = null;
    var footerHeight = footer ? footer.getBoundingClientRect().height : 0;
    
    var requiredDesktopGap = Math.max(80, window.innerHeight - baseFloatY);
    var bottomGap = isMobile ? (footerHeight + 90) : (footerHeight + requiredDesktopGap);
    if (!footer) bottomGap = isMobile ? 120 : requiredDesktopGap + 40; 
    
    if (activeList.dataset.bgap !== String(bottomGap)) {
      activeList.style.setProperty('padding-bottom', bottomGap + 'px', 'important');
      activeList.dataset.bgap = String(bottomGap);
    }

    if (!isMobile) {
      rows.forEach(function(row, index) {
        var details = row.querySelector('.ffwinks-soul-details-box');
        if (details) {
          var pad = (!isMobile && index > 0) ? '70px' : '';
          if (details.dataset.pad !== pad) {
            if (pad) details.style.setProperty('padding-top', pad, 'important');
            else details.style.removeProperty('padding-top');
            details.dataset.pad = pad;
          }
        }
      });
    } else {
      rows.forEach(function(row) {
        var details = row.querySelector('.ffwinks-soul-details-box');
        if (details && details.dataset.pad !== '') {
          details.style.removeProperty('padding-top');
          details.dataset.pad = '';
        }
      });
    }

    var transformValue = 'translate(-50%, -50%)';

    if (rows.length === 1) {
      if (isMobile) {
        // ── V2 fix: mobile single-item positions star to right of image ──
        var mobileSingleImg = rows[0].querySelector('.ffwinks-soul-img-box, .cart-item__left');
        var mobileSingleX = '50%';

        if (mobileSingleImg) {
          mobileSingleX = (mobileSingleImg.getBoundingClientRect().right + nudge_x) + 'px';
        }

        star.style.setProperty('position', 'fixed', 'important');
        star.style.setProperty('z-index', STAR_Z_INDEX, 'important');
        star.style.setProperty('left', mobileSingleX, 'important');
        star.style.setProperty('top', px_1_item + 'px', 'important');
        star.style.setProperty('transform', transformValue, 'important');
      } else if (isCart) {
        // ── V1 desktop cart: image-anchored with correct nudge values ──
        var targetX = '50%';
        var targetY = px_1_item + 'px';
        var img = rows[0].querySelector('.ffwinks-soul-img-box, .cart-item__left');

        if (img) {
          var rect = img.getBoundingClientRect();
          targetX = (rect.right + nudge_x) + 'px';
          targetY = (
            rect.top +
            (rect.height / 2) +
            CART_SINGLE_ITEM_NUDGE_Y +
            ffwinksGetCartTallSingleItemNudgeY()
          ) + 'px';
        }

        star.style.setProperty('position', 'fixed', 'important');
        star.style.setProperty('z-index', STAR_Z_INDEX, 'important');
        star.style.setProperty('left', targetX, 'important');
        star.style.setProperty('top', targetY, 'important');
        star.style.setProperty('transform', transformValue, 'important');
      } else {
        // ── V1 desktop wishlist: centered ──
        ffwinksCenterStar(star);
      }
      return;
    }

    var img1 = rows[rows.length - 2].querySelector('.ffwinks-soul-img-box, .cart-item__left') || rows[rows.length - 2];
    var img2 = rows[rows.length - 1].querySelector('.ffwinks-soul-img-box, .cart-item__left') || rows[rows.length - 1];
    if (!img1 || !img2) return;

    var rightEdgeX = img1.getBoundingClientRect().right;
    var rawGapCenterY;
    
    if (isMobile) {
      rawGapCenterY = (rows[rows.length - 2].getBoundingClientRect().bottom + rows[rows.length - 1].getBoundingClientRect().top) / 2;
    } else {
      rawGapCenterY = (img1.getBoundingClientRect().bottom + img2.getBoundingClientRect().top) / 2;
    }
    
    var nudgedGapY = rawGapCenterY + nudge_y;

    star.style.setProperty('position', 'fixed', 'important');
    star.style.setProperty('z-index', STAR_Z_INDEX, 'important');
    star.style.setProperty('left', (rightEdgeX + nudge_x) + 'px', 'important');
    star.style.setProperty('transform', transformValue, 'important');

    if (rows.length === 2) {
      star.style.setProperty('top', (nudgedGapY + nudge_2_item) + 'px', 'important');
      return;
    }

    if (nudgedGapY <= baseFloatY) {
      star.style.setProperty('top', nudgedGapY + 'px', 'important');
    } else {
      star.style.setProperty('top', baseFloatY + 'px', 'important');
    }
  }

  var scrollTick = false;
  function onOverlayScroll() {
    if (!scrollTick) {
      window.requestAnimationFrame(function() {
        ffwinksUpdateStar();
        scrollTick = false;
      });
      scrollTick = true;
    }
  }
  
  if (wishlistOverlay) wishlistOverlay.addEventListener('scroll', onOverlayScroll);
  if (cartOverlay) cartOverlay.addEventListener('scroll', onOverlayScroll);
  window.addEventListener('scroll', onOverlayScroll); 
  // ==========================================


  function debounce(fn, wait) {
    var t;
    return function () {
      var args = arguments;
      clearTimeout(t);
      t = setTimeout(function () { fn.apply(null, args); }, wait);
    };
  }

  function setOverlayOffset() {
    var h = header ? header.getBoundingClientRect().bottom : 60;
    document.documentElement.style.setProperty('--header-overlay-offset', h + 'px');
  }
  setOverlayOffset();
  window.addEventListener('resize', setOverlayOffset);

  function getMobileMenu() {
    return document.getElementById('ffwinks-mobile-menu');
  }

  function getMobileMenuDetails() {
    return document.getElementById('Details-menu-drawer-container');
  }

  function getMobileMenuTrigger() {
    return document.querySelector('header-drawer summary.header__icon--menu');
  }

  function isMobileViewport() {
    return window.matchMedia('(max-width: 749px)').matches;
  }

  function isMobileMenuOpen() {
    var mobileMenu = getMobileMenu();
    return !!(mobileMenu && mobileMenu.classList.contains('ffwinks-fullscreen--open'));
  }

  function syncMobileMenuState(isOpen) {
    var mobileMenu = getMobileMenu();
    var details = getMobileMenuDetails();
    var summary = getMobileMenuTrigger();

    if (mobileMenu) {
      mobileMenu.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
    }

    if (details) {
      details.classList.toggle('menu-open', isOpen);
      if (isOpen) {
        details.setAttribute('open', '');
      } else {
        details.removeAttribute('open');
      }
    }

    if (summary) {
      summary.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    }
  }

  function closeMobileMenu() {
    var mobileMenu = getMobileMenu();
    if (!mobileMenu) return;

    mobileMenu.classList.remove('ffwinks-fullscreen--open');
    syncMobileMenuState(false);

    if (!wishlistOverlay.classList.contains('ffwinks-fullscreen--open') &&
        !cartOverlay.classList.contains('ffwinks-fullscreen--open')) {
      document.body.classList.remove('ffwinks-body-lock');
    }
  }

  function openMobileMenu() {
    var mobileMenu = getMobileMenu();
    if (!mobileMenu || !isMobileViewport()) return;

    closeAll();
    closeFullscreen(wishlistOverlay);
    closeFullscreen(cartOverlay);
    setOverlayOffset();

    mobileMenu.classList.add('ffwinks-fullscreen--open');
    syncMobileMenuState(true);
    document.body.classList.add('ffwinks-body-lock');
  }

  function toggleMobileMenu() {
    if (isMobileMenuOpen()) {
      closeMobileMenu();
    } else {
      openMobileMenu();
    }
  }

  document.addEventListener('click', function (e) {
    var mobileMenuTrigger = e.target.closest('header-drawer summary.header__icon--menu');
    if (mobileMenuTrigger && isMobileViewport()) {
      e.preventDefault();
      e.stopImmediatePropagation();
      toggleMobileMenu();
      return;
    }

    if (!isMobileMenuOpen()) return;

    var mobileMenuLink = e.target.closest('#ffwinks-mobile-menu a[href]');
    if (!mobileMenuLink) return;
    if (mobileMenuLink.matches('a[href*="/account"], a[href*="/login"]')) return;

    closeMobileMenu();
  }, true);

  function getWishlist() {
    try { return JSON.parse(localStorage.getItem('ffwinks_wishlist') || '[]'); }
    catch (e) { return []; }
  }

  function saveWishlist(list) {
    localStorage.setItem('ffwinks_wishlist', JSON.stringify(list));
  }

  function getProductFromSparkle(sparkleEl) {
    var card = sparkleEl.closest('.product-card, .shop-product, .newin-product, [data-product-id], .card, .product-item');
    var rawSizes = (card && card.dataset.availableSizes) ? card.dataset.availableSizes : (sparkleEl.dataset.availableSizes || '');
    var rawColors = (card && card.dataset.availableColors) ? card.dataset.availableColors : (sparkleEl.dataset.availableColors || '');

    var availSizes = rawSizes ? rawSizes.split(',') : [];
    var availColors = rawColors ? rawColors.split(',') : [];

    if (sparkleEl.dataset.ffwinksSparkle !== undefined) {
      var vid   = sparkleEl.dataset.variantId   || null;
      var title = sparkleEl.dataset.title       || '';
      if (!title && !vid) return null;
      return {
        variant_id:      vid,
        title:           title,
        price:           parseFloat(sparkleEl.dataset.price || '0') || 0,
        price_formatted: sparkleEl.dataset.priceFormatted || '',
        currency:        sparkleEl.dataset.currency || (window.Shopify && window.Shopify.currency ? window.Shopify.currency.active : '£'),
        image:           sparkleEl.dataset.image || '',
        url:             sparkleEl.dataset.url   || '',
        available_sizes: availSizes,
        available_colors: availColors,
        selected_size:   '',
        selected_color:  ''
      };
    }

    if (!card) return null;

    var nameEl  = card.querySelector('.product-name, .shop-product-name, .newin-product-name, [class*="product-title"], [class*="card-title"], h2, h3');
    var priceEl = card.querySelector('.product-price, .shop-product-price, .newin-product-price, [class*="price"]');
    var imgEl   = card.querySelector('img:not(.product-sparkle-icon):not(.shop-product-icon):not(.newin-product-icon):not([class*="icon"]):not([data-ffwinks-sparkle] img)');

    if (!nameEl) return null;
    var rawPrice = priceEl ? priceEl.textContent.replace(/[^0-9.]/g, '') : '0';

    return {
      variant_id:      card.dataset.variantId || card.dataset.productId || null,
      title:           nameEl.textContent.trim(),
      price:           parseFloat(rawPrice) || 0,
      price_formatted: priceEl ? priceEl.textContent.trim() : '',
      currency:        window.Shopify && window.Shopify.currency ? window.Shopify.currency.active : '£',
      image:           imgEl ? imgEl.src : '',
      url:             '',
      available_sizes: availSizes,
      available_colors: availColors,
      selected_size:   '',
      selected_color:  ''
    };
  }

  function updateAllSparkleStates() {
    var wl    = getWishlist();
    var ids   = wl.map(function (i) { return i.variant_id; }).filter(Boolean);
    var names = wl.map(function (i) { return i.title; });
    document.querySelectorAll('.product-sparkle-icon, .shop-product-icon, .newin-product-icon').forEach(function (sparkle) {
      var vid = sparkle.dataset && sparkle.dataset.variantId ? sparkle.dataset.variantId : null;
      var title = sparkle.dataset && sparkle.dataset.title ? sparkle.dataset.title : '';

      var card = sparkle.closest('.product-card, .shop-product, .newin-product, [data-product-id]');
      if (!vid && card) {
        vid = card.dataset.variantId || null;
      }
      if (!title && card) {
        var nameEl = card.querySelector('.product-name, .shop-product-name, .newin-product-name, [class*="product-title"]');
        title = nameEl ? nameEl.textContent.trim() : '';
      }

      var inList = (vid && ids.indexOf(String(vid)) !== -1) || (title && names.indexOf(title) !== -1);
      sparkle.classList.toggle('ffwinks-sparkle--active', inList);
    });
    document.querySelectorAll('[data-ffwinks-sparkle]').forEach(function (btn) {
      var vid   = btn.dataset.variantId || null;
      var title = btn.dataset.title     || '';
      var inList = (vid && ids.indexOf(String(vid)) !== -1) || (title && names.indexOf(title) !== -1);
      btn.classList.toggle('ffwinks-sparkle--active', inList);
      var img = btn.querySelector('img');
      if (img) {
        img.src = inList ? btn.dataset.svgFilled : btn.dataset.svgEmpty;
      }
    });
  }

  var scheduleSparkleSync = debounce(function () {
    updateAllSparkleStates();
  }, 80);

  function toggleWishlistItem(sparkleEl) {
    var item = getProductFromSparkle(sparkleEl);
    if (!item) return;

    var wl  = getWishlist();
    var idx = wl.findIndex(function (i) {
