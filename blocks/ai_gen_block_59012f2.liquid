{% doc %}
  @prompt
    Create a custom section that recreates this exact layout:
    
    A perfectly centered 2×2 grid of four large rounded rectangles.
    Each rectangle has:
    – very light grey background (#F3F3F3)
    – large 40–50px rounded corners
    – equal spacing between the 4 blocks
    
    In the center, where the four rectangles meet, create the exact curved inward cross shape shown in the reference image:
    – four smooth inward curves
    – thin grey stroke
    – perfectly symmetrical
    – identical spacing and curve sharpness as the reference
    
    In the center, add the text: “44’s Picks” in small, thin, grey font.
    On the left curve, add the text “Unveil the soul” rotated and aligned exactly like in the photo.
    
    Functionality:
    Each of the four rectangles must be clickable and link to a selected collection.
    Add settings to choose the 4 collections (Top Left, Top Right, Bottom Left, Bottom Right).
    
    Structure:
    – Full-width section
    – Keep everything centered
    – Max width around 85–90% of the screen
    – Maintain exact proportions from the reference
    – Maintain giant rounded corners exactly like the image
    – The center curved cross must be rendered using SVG so it stays sharp and identical to the screenshot.
    
    Responsive Behavior:
    On mobile:
    – Stack into two rows
    – Curved cross simplifies but still keeps a soft inward curve in the center
    – Text remains centered
    
    Section Settings Needed:
    – Collection picker (x4)
    – Center text field (“44’s Picks”)
    – Side label text field (“Unveil the soul”)
    – Background color control for the rectangles
    – Padding controls
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-curved-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
  }

  .ai-curved-grid-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}%;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-curved-grid-wrapper-{{ ai_gen_id }} {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: {{ block.settings.grid_gap }}px;
    aspect-ratio: 1;
    width: 100%;
  }

  .ai-curved-grid-item-{{ ai_gen_id }} {
    position: relative;
    background-color: {{ block.settings.rectangle_bg_color }};
    border-radius: {{ block.settings.corner_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    cursor: pointer;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-curved-grid-item-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  .ai-curved-grid-center-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
    pointer-events: none;
  }

  .ai-curved-grid-center-text-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 10px;
    font-weight: 300;
    color: {{ block.settings.text_color }};
    white-space: nowrap;
    pointer-events: none;
    z-index: 11;
  }

  .ai-curved-grid-side-text-{{ ai_gen_id }} {
    position: absolute;
    left: calc(50% - {{ block.settings.side_text_distance }}px);
    top: 50%;
    transform: translate(-50%, -50%) rotate(-90deg);
    transform-origin: center;
    font-size: 9px;
    font-weight: 300;
    color: {{ block.settings.text_color }};
    white-space: nowrap;
    pointer-events: none;
    z-index: 11;
  }

  .ai-curved-grid-collection-title-{{ ai_gen_id }} {
    font-size: 10px;
    font-weight: 600;
    color: {{ block.settings.collection_title_color }};
    text-align: center;
    padding: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-curved-grid-wrapper-{{ ai_gen_id }} {
      gap: {{ block.settings.grid_gap_mobile }}px;
    }

    .ai-curved-grid-item-{{ ai_gen_id }} {
      border-radius: {{ block.settings.corner_radius_mobile }}px;
    }

    .ai-curved-grid-center-text-{{ ai_gen_id }} {
      font-size: 10px;
    }

    .ai-curved-grid-side-text-{{ ai_gen_id }} {
      font-size: 9px;
      left: calc(50% - {{ block.settings.side_text_distance | times: 0.7 }}px);
    }

    .ai-curved-grid-collection-title-{{ ai_gen_id }} {
      font-size: 10px;
    }
  }
{% endstyle %}

<curved-grid-{{ ai_gen_id }} class="ai-curved-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-curved-grid-container-{{ ai_gen_id }}">
    <div class="ai-curved-grid-wrapper-{{ ai_gen_id }}">
      {% if block.settings.collection_top_left %}
        <a href="{{ block.settings.collection_top_left.url }}" class="ai-curved-grid-item-{{ ai_gen_id }}">
          <span class="ai-curved-grid-collection-title-{{ ai_gen_id }}">{{ block.settings.collection_top_left.title }}</span>
        </a>
      {% else %}
        <div class="ai-curved-grid-item-{{ ai_gen_id }}">
          <span class="ai-curved-grid-collection-title-{{ ai_gen_id }}">Top Left Collection</span>
        </div>
      {% endif %}

      {% if block.settings.collection_top_right %}
        <a href="{{ block.settings.collection_top_right.url }}" class="ai-curved-grid-item-{{ ai_gen_id }}">
          <span class="ai-curved-grid-collection-title-{{ ai_gen_id }}">{{ block.settings.collection_top_right.title }}</span>
        </a>
      {% else %}
        <div class="ai-curved-grid-item-{{ ai_gen_id }}">
          <span class="ai-curved-grid-collection-title-{{ ai_gen_id }}">Top Right Collection</span>
        </div>
      {% endif %}

      {% if block.settings.collection_bottom_left %}
        <a href="{{ block.settings.collection_bottom_left.url }}" class="ai-curved-grid-item-{{ ai_gen_id }}">
          <span class="ai-curved-grid-collection-title-{{ ai_gen_id }}">{{ block.settings.collection_bottom_left.title }}</span>
        </a>
      {% else %}
        <div class="ai-curved-grid-item-{{ ai_gen_id }}">
          <span class="ai-curved-grid-collection-title-{{ ai_gen_id }}">Bottom Left Collection</span>
        </div>
      {% endif %}

      {% if block.settings.collection_bottom_right %}
        <a href="{{ block.settings.collection_bottom_right.url }}" class="ai-curved-grid-item-{{ ai_gen_id }}">
          <span class="ai-curved-grid-collection-title-{{ ai_gen_id }}">{{ block.settings.collection_bottom_right.title }}</span>
        </a>
      {% else %}
        <div class="ai-curved-grid-item-{{ ai_gen_id }}">
          <span class="ai-curved-grid-collection-title-{{ ai_gen_id }}">Bottom Right Collection</span>
        </div>
      {% endif %}

      <div class="ai-curved-grid-center-{{ ai_gen_id }}">
        <svg width="{{ block.settings.cross_size }}" height="{{ block.settings.cross_size }}" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M 100 0 Q 80 20, 80 40 L 80 80 Q 80 100, 60 100 L 40 100 Q 20 100, 0 120 L 0 80 Q 20 80, 40 80 L 60 80 Q 80 80, 80 60 L 80 40 Q 80 20, 100 0 Z" fill="none" stroke="{{ block.settings.cross_stroke_color }}" stroke-width="{{ block.settings.cross_stroke_width }}"/>
          <path d="M 100 0 Q 120 20, 120 40 L 120 80 Q 120 100, 140 100 L 160 100 Q 180 100, 200 120 L 200 80 Q 180 80, 160 80 L 140 80 Q 120 80, 120 60 L 120 40 Q 120 20, 100 0 Z" fill="none" stroke="{{ block.settings.cross_stroke_color }}" stroke-width="{{ block.settings.cross_stroke_width }}"/>
          <path d="M 100 200 Q 80 180, 80 160 L 80 120 Q 80 100, 60 100 L 40 100 Q 20 100, 0 80 L 0 120 Q 20 120, 40 120 L 60 120 Q 80 120, 80 140 L 80 160 Q 80 180, 100 200 Z" fill="none" stroke="{{ block.settings.cross_stroke_color }}" stroke-width="{{ block.settings.cross_stroke_width }}"/>
          <path d="M 100 200 Q 120 180, 120 160 L 120 120 Q 120 100, 140 100 L 160 100 Q 180 100, 200 80 L 200 120 Q 180 120, 160 120 L 140 120 Q 120 120, 120 140 L 120 160 Q 120 180, 100 200 Z" fill="none" stroke="{{ block.settings.cross_stroke_color }}" stroke-width="{{ block.settings.cross_stroke_width }}"/>
        </svg>
      </div>

      {% if block.settings.center_text != blank %}
        <div class="ai-curved-grid-center-text-{{ ai_gen_id }}">
          {{ block.settings.center_text }}
        </div>
      {% endif %}

      {% if block.settings.side_text != blank %}
        <div class="ai-curved-grid-side-text-{{ ai_gen_id }}">
          {{ block.settings.side_text }}
        </div>
      {% endif %}
    </div>
  </div>
</curved-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class CurvedGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.adjustCrossSize();
        window.addEventListener('resize', () => this.adjustCrossSize());
      }

      adjustCrossSize() {
        const wrapper = this.querySelector('.ai-curved-grid-wrapper-{{ ai_gen_id }}');
        const centerSvg = this.querySelector('.ai-curved-grid-center-{{ ai_gen_id }} svg');
        
        if (wrapper && centerSvg) {
          const gap = window.innerWidth <= 749 ? {{ block.settings.grid_gap_mobile }} : {{ block.settings.grid_gap }};
          const wrapperWidth = wrapper.offsetWidth;
          const crossSize = gap * 2.5;
          
          centerSvg.setAttribute('width', crossSize);
          centerSvg.setAttribute('height', crossSize);
        }
      }
    }

    customElements.define('curved-grid-{{ ai_gen_id }}', CurvedGrid{{ ai_gen_id }});
  })();
</script>

