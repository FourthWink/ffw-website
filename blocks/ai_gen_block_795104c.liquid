{% doc %}
  @prompt
    Add a "Coming Soon" text overlay centered over the video block on the password page. The text should be positioned absolutely over the video, centered both horizontally and vertically. Style it with a large, elegant font, white color, and a subtle text shadow so it's readable over the video. It should not block any interaction and stay responsive on mobile.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-coming-soon-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 10;
  }

  .ai-coming-soon-text-{{ ai_gen_id }} {
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_font.weight }};
    font-size: 10px;
    color: {{ block.settings.text_color }};
    text-shadow: {{ block.settings.shadow_x }}px {{ block.settings.shadow_y }}px {{ block.settings.shadow_blur }}px {{ block.settings.shadow_color }};
    text-align: center;
    text-transform: {% if block.settings.uppercase %}uppercase{% else %}none{% endif %};
    margin: 0;
    padding: 0 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-coming-soon-text-{{ ai_gen_id }} {
      font-size: 10px;
    }
  }
{% endstyle %}

<div class="ai-coming-soon-overlay-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <h2 class="ai-coming-soon-text-{{ ai_gen_id }}">{{ block.settings.text }}</h2>
</div>

{% schema %}
{
  "name": "Coming soon overlay",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Coming Soon"
    },
    {
      "type": "font_picker",
      "id": "text_font",
      "label": "Font",
      "default": "montserrat_n4"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Desktop font size",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Mobile font size",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "checkbox",
      "id": "uppercase",
      "label": "Uppercase",
      "default": true
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Text shadow"
    },
    {
      "type": "range",
      "id": "shadow_x",
      "label": "Horizontal offset",
      "min": -10,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "shadow_y",
      "label": "Vertical offset",
      "min": -10,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "range",
      "id": "shadow_blur",
      "label": "Blur radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "color",
      "id": "shadow_color",
      "label": "Shadow color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Coming soon overlay"
    }
  ]
}
{% endschema %}
