{%- assign block_settings = block.settings -%}
<div
  id="ProductInformation-{{ section.id }}"
  class="
    product-details
    {% if block_settings.sticky_details_desktop %} sticky-content--desktop{% endif %}
    {% if block_settings.height == 'fill' -%} full-height--desktop{% endif -%}
  "
  style="--details-position: {{ block_settings.details_position }};"
  data-testid="product-information-details"
  {% if settings.transition_to_main_product %}
    data-view-transition-type="product-details"
  {% endif %}
>
  {% capture children %}
    <div class="view-product-title">
      <a
        href="{{ closest.product.selected_or_first_available_variant.url }}"
        class="link"
      >
        {{- closest.product.title }}
      </a>
    </div>

    {%- comment -%} ► FFW: Mobile price + title + sparkle row {%- endcomment -%}
    {%- assign pdp_product = closest.product -%}
    {%- assign pdp_variant = pdp_product.selected_or_first_available_variant -%}
    <div class="ffw-pdp-header-row" id="ffw-pdp-header-row-{{ section.id }}">
      <div class="ffw-pdp-price" id="ffw-pdp-price-{{ section.id }}">
        {{- pdp_variant.price | money -}}
        {%- if pdp_variant.compare_at_price > pdp_variant.price -%}
          <s class="ffw-pdp-compare-price">{{- pdp_variant.compare_at_price | money -}}</s>
        {%- endif -%}
      </div>
      <div class="ffw-pdp-title">{{- pdp_product.title -}}</div>
      <button
        class="ffw-pdp-sparkle-btn shop-product-icon"
        id="ffw-pdp-sparkle-{{ section.id }}"
        data-ffwinks-sparkle="true"
        type="button"
        aria-label="Add {{ pdp_product.title | escape }} to wishlist"
        data-variant-id="{{ pdp_variant.id }}"
        data-title="{{ pdp_product.title | escape }}"
        data-price="{{ pdp_variant.price | divided_by: 100.0 }}"
        data-price-formatted="{{ pdp_variant.price | money }}"
        data-image="{{ pdp_product.featured_media | image_url: width: 300 }}"
        data-url="{{ pdp_product.url }}"
        data-svg-empty="{{ 'sparkle.svg' | asset_url }}"
        data-svg-filled="{{ 'sparkle-icon.svg' | asset_url }}"
      >
        <img
          src="{{ 'sparkle.svg' | asset_url }}"
          alt=""
          class="ffw-pdp-sparkle-img"
          style="pointer-events:none;"
        >
      </button>
    </div>
    {%- comment -%} ► END FFW mobile row {%- endcomment -%}

    {% content_for 'blocks' %}
  {% endcapture %}

  {% render 'group', children: children, settings: block_settings, shopify_attributes: block.shopify_attributes %}
</div>

<script>
(function () {
  /*
    Keeps the custom PDP header in sync with variant changes. The native theme
    updates the main product form; this block owns the price text and wishlist
    sparkle shown beside the custom title/price row.
  */
  var sectionId  = {{ section.id | json }};
  var sparkleBtn = document.getElementById('ffw-pdp-sparkle-' + sectionId);
  var priceEl    = document.getElementById('ffw-pdp-price-' + sectionId);

  if (!sparkleBtn || !priceEl) return;

  // ── Listen on the theme's own variant events (events.js) ──────────────
  // Prefer theme variant events when available; this fires when a variant is picked.
  document.addEventListener('variant:selected', function (e) {
    var v = e.detail && e.detail.resource;
    if (v) updateSparkle(v);
  });

  // This fires after the page DOM has been updated with new variant HTML.
  document.addEventListener('variant:update', function (e) {
    var v = e.detail && e.detail.resource;
    if (v) updateSparkle(v);
  });

  // ── Also watch the hidden [name="id"] input directly as a fallback ─────
  // Fall back to hidden variant inputs because some AI-generated picker blocks
  // update form fields without emitting the theme variant events above.
  function bindInputs() {
    document.querySelectorAll('input[name="id"], select[name="id"]').forEach(function (input) {
      if (input.dataset.ffwBound) return;
      input.dataset.ffwBound = '1';
      input.addEventListener('change', function () {
        // Fetch fresh variant data from Shopify AJAX API.
        var vid = this.value;
        var handle = {{ closest.product.handle | json }};
        fetch('/products/' + handle + '.js')
          .then(function (r) { return r.json(); })
          .then(function (product) {
            var variant = product.variants.find(function (v) {
              return String(v.id) === String(vid);
            });
            if (variant) updateSparkle(variant);
          })
          .catch(function () {});
      });
    });
  }

  // Run now and after Shopify re-renders the section in the theme editor.
  bindInputs();
  document.addEventListener('shopify:section:load', bindInputs);

  // ── Initial wishlist state sync ────────────────────────────────────────
  syncWishlistState();

  // Re-sync when another tab/card changes the wishlist localStorage entry.
  window.addEventListener('storage', function (e) {
    if (e.key === 'ffwinks_wishlist') syncWishlistState();
  });

  // ── Core functions ─────────────────────────────────────────────────────
  function updateSparkle(variant) {
    sparkleBtn.dataset.variantId      = variant.id;
    sparkleBtn.dataset.price          = (variant.price / 100).toFixed(2);
    sparkleBtn.dataset.priceFormatted = formatMoney(variant.price);

    var priceHtml = formatMoney(variant.price);
    if (variant.compare_at_price && variant.compare_at_price > variant.price) {
      priceHtml += ' <s class="ffw-pdp-compare-price">' + formatMoney(variant.compare_at_price) + '</s>';
    }
    priceEl.innerHTML = priceHtml;

    syncWishlistState();
  }

  function syncWishlistState() {
    try {
      var list   = JSON.parse(localStorage.getItem('ffwinks_wishlist') || '[]');
      var ids    = list.map(function (i) { return i.variant_id; }).filter(Boolean);
      var names  = list.map(function (i) { return i.title; });
      var vid    = sparkleBtn.dataset.variantId;
      var title  = sparkleBtn.dataset.title;
      var inList = (vid && ids.indexOf(vid) !== -1) || (title && names.indexOf(title) !== -1);
      var img    = sparkleBtn.querySelector('img');
      sparkleBtn.classList.toggle('ffwinks-sparkle--active', inList);
      if (img) img.src = inList ? sparkleBtn.dataset.svgFilled : sparkleBtn.dataset.svgEmpty;
    } catch (e) {}
  }

  function formatMoney(cents) {
    var fmt = {{ shop.money_format | json }};
    return fmt ?
      fmt.replace(/\{\{amount\}\}/g, (cents / 100).toFixed(2))
   .replace(/\{\{amount_no_decimals\}\}/g, Math.round(cents / 100))
      : '£' + (cents / 100).toFixed(2);
  }
})();
</script>

{% stylesheet %}
  /* Clear padding on mobile, if not full-width */
  @media screen and (max-width: 749px) {
    .product-information.section--page-width .product-details > .group-block {
      padding-inline: 0;
    }
  }

  .view-product-title {
    display: none;
  }

  /* ► FFW: Price + Title + Sparkle row — mobile only */
  .ffw-pdp-header-row {
    display: flex;
    align-items: center;
    gap: 50px; /* <-- I INCREASED THIS FROM 10px TO 50px */
    flex-wrap: nowrap;
  }

.ffw-pdp-price {
  padding-left: 18px;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  font-size: 9px;
}

.ffw-pdp-compare-price {
  display: block;
  font-size: 9px;
  margin-top: 2px;
}

  .ffw-pdp-title { 
    padding-left: 12px;
    flex: 1;
    font-size: 10px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .ffw-pdp-sparkle-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding-right: -5px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .ffw-pdp-sparkle-img {
    width: 20px;
    height: 20px;
  }

  /* Hide mobile row on desktop */
  @media screen and (min-width: 750px) {
    .ffw-pdp-header-row {
      display: none;
    }
  }

  /* Hide desktop price + title (header_group) on mobile.
     Shopify renders group blocks with a class like group-gap-mobile-{blockid}.
     The header_group block id becomes 'group-gap-mobile-headergroup' */
  @media screen and (max-width: 749px) {
    .product-details .group-gap-mobile-headergroup {
      display: none !important;
    }
  }
  /* ► END FFW mobile row */

  /* Container styles */
  .product-details {
    display: flex;
    align-self: start;
    justify-content: center;
  }

  @media screen and (min-width: 750px) {
    .product-details > .group-block {
      height: min-content;
    }

    .full-height--desktop {
      height: 100%;
      max-height: calc(100vh - var(--header-group-height, 0));
      min-height: fit-content;
    }

    .full-height--desktop .group-block {
      align-self: var(--details-position, 'flex-start');
    }
  }
{% endstylesheet %}

