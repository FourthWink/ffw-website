{% doc %}
  @prompt
    Create a custom Online Store 2.0 section called “Curved 2x2 Product Grid”.
    This section must show products (not collections) in a 2 by 2 grid that looks like four large rounded rectangles, similar to a soft cards layout. Ignore any star or center icon; I only want the four rounded rectangles.
    
    Layout & behavior
    
    Desktop: 2 columns × 2 rows (exactly four cards visible).
    
    Mobile: also 2 × 2, centered on the page (no weird vertical stack of 4 tall blocks).
    
    Each card is the same width and height, with a light grey background (#F6F6F6), and very rounded outer corners.
    
    Where the four cards meet in the center, the inner corners are also curved inwards, creating a smooth clover / four-leaf shape.
    
    Use CSS so that:
    
    The four outer corners share one radius value.
    
    The four inner corners share a separate radius value.
    
    For example: top-left card has outer radius on top-left and inner radius on bottom-right, etc.
    
    The whole grid should be centered in the section with equal padding around it.
    
    Content
    
    Each card represents a product from a selected collection (default collection = “All products”):
    
    Product featured image (cover the card, object-fit: cover, with a bit of padding from the edges).
    
    Under the image, show product title and price.
    
    Optional small “View product” link (no big add-to-cart button).
    
    Theme editor settings
    
    Add these settings so I can customize the design without editing code:
    
    Collection selector – pick which collection to show products from (default “All products”).
    
    Number of products – max 4, fill the grid in reading order (top-left to bottom-right).
    
    Outer corner radius (px) – range 0–80, default 40.
    
    Inner curve radius (px) – range 0–80, default 40 (controls only the four inner corners where the cards meet).
    
    Card height (px) – range 250–500, default 360.
    
    Card background color – default #F6F6F6.
    
    Grid gap (px) – range 0–32, default 16.
    
    Section padding top / bottom (px) – to control whitespace around the grid., theres only one product on display i want the other 3 , remove prices and product name and view product 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign collection = block.settings.collection
  assign products_to_show = block.settings.products_to_show
  assign outer_radius = block.settings.outer_radius
  assign inner_radius = block.settings.inner_radius
  assign card_height = block.settings.card_height
  assign card_bg = block.settings.card_background
  assign grid_gap = block.settings.grid_gap
  assign padding_top = block.settings.padding_top
  assign padding_bottom = block.settings.padding_bottom

  if collection == blank
    assign collection = collections.all
  endif

  assign products = collection.products
%}

{% style %}
  .ai-curved-grid-{{ ai_gen_id }} {
    display: block;
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
    width: 100%;
  }

  .ai-curved-grid-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: {{ grid_gap }}px;
    max-width: 800px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-curved-grid-card-{{ ai_gen_id }} {
    position: relative;
    background-color: {{ card_bg }};
    height: {{ card_height }}px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .ai-curved-grid-card-{{ ai_gen_id }}:nth-child(1) {
    border-top-left-radius: {{ outer_radius }}px;
    border-bottom-right-radius: {{ inner_radius }}px;
  }

  .ai-curved-grid-card-{{ ai_gen_id }}:nth-child(2) {
    border-top-right-radius: {{ outer_radius }}px;
    border-bottom-left-radius: {{ inner_radius }}px;
  }

  .ai-curved-grid-card-{{ ai_gen_id }}:nth-child(3) {
    border-bottom-left-radius: {{ outer_radius }}px;
    border-top-right-radius: {{ inner_radius }}px;
  }

  .ai-curved-grid-card-{{ ai_gen_id }}:nth-child(4) {
    border-bottom-right-radius: {{ outer_radius }}px;
    border-top-left-radius: {{ inner_radius }}px;
  }

  .ai-curved-grid-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    padding: 16px;
    overflow: hidden;
  }

  .ai-curved-grid-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 8px;
  }

  .ai-curved-grid-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #e0e0e0;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-curved-grid-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @media screen and (max-width: 749px) {
    .ai-curved-grid-container-{{ ai_gen_id }} {
      max-width: 500px;
      padding: 0 16px;
    }

    .ai-curved-grid-card-{{ ai_gen_id }} {
      height: {{ card_height | times: 0.8 }}px;
    }

    .ai-curved-grid-image-wrapper-{{ ai_gen_id }} {
      padding: 12px;
    }
  }
{% endstyle %}

<div class="ai-curved-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-curved-grid-container-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% assign index = forloop.index0 %}
      {% assign product = products[index] %}
      
      {% if product and index < products_to_show %}
        <a href="{{ product.url }}" class="ai-curved-grid-card-{{ ai_gen_id }}">
          <div class="ai-curved-grid-image-wrapper-{{ ai_gen_id }}">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 400 }}"
                alt="{{ product.featured_image.alt | escape }}"
                class="ai-curved-grid-image-{{ ai_gen_id }}"
                loading="lazy"
                width="400"
                height="400"
              >
            {% else %}
              <div class="ai-curved-grid-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
        </a>
      {% else %}
        <div class="ai-curved-grid-card-{{ ai_gen_id }}">
          <div class="ai-curved-grid-image-wrapper-{{ ai_gen_id }}">
            <div class="ai-curved-grid-placeholder-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Curved 2x2 product grid",
  "settings": [
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Number of products",
      "default": 4
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "outer_radius",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Outer corner radius",
      "default": 40
    },
    {
      "type": "range",
      "id": "inner_radius",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Inner curve radius",
      "default": 40
    },
    {
      "type": "range",
      "id": "card_height",
      "min": 250,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Card height",
      "default": 360
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 0,
      "max": 32,
      "step": 4,
      "unit": "px",
      "label": "Grid gap",
      "default": 16
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#F6F6F6"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Curved 2x2 product grid"
    }
  ]
}
{% endschema %}
