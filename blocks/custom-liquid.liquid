{% if template.name == 'product' %}

  {%- liquid
    assign product_title    = product.title | escape
    assign product_price    = product.selected_or_first_available_variant.price | divided_by: 100.0
    assign product_price_fmt = product.selected_or_first_available_variant.price | money
    assign product_image    = product.featured_media | image_url: width: 300
    assign product_url      = product.url
    assign variant_id       = product.selected_or_first_available_variant.id
  -%}

  {{- '' -}}

  {{- '' -}}
  <div id="ffwinks-mobile-atc" class="ffwinks-mobile-atc">
    <button type="button" class="floating-atc-btn ffwinks-mobile-atc-btn">
      Add to cart
    </button>
  </div>

  <style>
  /* ── Hide theme's native ATC everywhere ── */
  button[name=add],
  .product-form__submit {
    position: absolute !important;
    left: -9999px !important;
    visibility: hidden !important;
  }

  /* Wishlist sparkle is defined in sections/ffw-product-ui.liquid */

  /* ─────────────────────────────
     DESKTOP FLOATING STAR ATC
  ───────────────────────────── */
  .floating-atc {
    position: fixed;
    top: 50vh;
    left: 50vw;
    transform: translate(-50%, -50%);
    z-index: 999999;
    transition: opacity 0.2s ease, visibility 0.2s ease;

    /*
      Exclude from Shopify's View Transitions API.
      Without this, when navigating TO a product page the browser sets
      view-transition-name: main-content on <main>, which creates a new
      containing block — breaking position:fixed and offsetting the star.
    */
    view-transition-name: none !important;
  }
.floating-atc-btn,
  .ffwinks-img-btn-wrap {
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
  }
  .inverted-star {
    filter: invert(1);
    mix-blend-mode: normal;
  }
  .floating-atc-text {
    color: #666 !important;
    font-weight: 700 !important; 
    -webkit-text-stroke: 0.5px #666 !important; /* Forces the text to thicken */
  }
  /* Chaining two classes doubles the specificity, beating the single-class 'normal' rule */
  .ffwinks-img-label.floating-atc-text {
    font-weight: bold !important;
  }
  body.cart-overlay-open .floating-atc,
  body.ffwinks-adding .floating-atc {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }
  .floating-atc-btn:hover .floating-atc-text { color: #000; }

  /* Desktop: star visible, mobile bar hidden */
  .floating-atc--desktop { display: flex; }
  #ffwinks-mobile-atc    { display: none; }

  /* ─────────────────────────────
     MOBILE ATC BAR  (<=749px)
  ───────────────────────────── */
  @media (max-width: 749px) {
    #ffwinks-product-sparkle {
      display: none;
    }
    .floating-atc--desktop {
      display: none !important;
    }
    #ffwinks-mobile-atc {
      display: flex;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 999999;
      padding: 12px 20px;
      padding-bottom: calc(12px + env(safe-area-inset-bottom, 0px));
      background: #fff;
      border-top: 1px solid #eee;
      box-sizing: border-box;
    }
    .ffwinks-mobile-atc-btn {
      width: 100%;
      padding: 15px 0;
      background: #000 !important;
      color: #fff !important;
      border: none !important;
      border-radius: 100px;
      font-size: 10px;
      font-weight: 500;
      cursor: pointer;
      transition: opacity 0.15s ease;
    }
    .ffwinks-mobile-atc-btn:active {
      opacity: 0.7;
    }
    body.cart-overlay-open #ffwinks-mobile-atc,
    body.ffwinks-adding #ffwinks-mobile-atc {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }
    body {
      padding-bottom: calc(72px + env(safe-area-inset-bottom, 0px)) !important;
    }
  }
  </style>

  <script>
  // ── Inject the floating star directly onto <body> ──
  // This keeps it outside <main> so Shopify's view-transition-name: main-content
  // can never affect it. view-transition-name: none in CSS is a second line of defence.
  (function () {
    var STAR_ID = 'ffwinks-floating-atc';
    var SOUL_URL = {{ 'soul.svg' | asset_url | json }};

    function inject() {
      if (document.getElementById(STAR_ID)) return;

      var wrap = document.createElement('div');
      wrap.id = STAR_ID;
      wrap.className = 'floating-atc floating-atc--desktop';
      wrap.innerHTML =
        '<button type="button" class="ffwinks-soul-action-bottom floating-atc-btn" aria-label="Add to cart">' +
          '<div class="ffwinks-img-btn-wrap">' +
            '<img src="' + SOUL_URL + '" alt="Star" class="ffwinks-action-img inverted-star">' +
<span class="ffwinks-img-label floating-atc-text" style="font-weight: 900 !important; color: #00FF00 !important; -webkit-text-stroke: 1px #00FF00 !important;">Add to cart</span>          '</div>' +
        '</button>';

      document.body.appendChild(wrap);
    }

    if (document.body) {
      inject();
    } else {
      document.addEventListener('DOMContentLoaded', inject);
    }
  })();

  // ── Deselect all variant options on first page load (no ?variant= in URL) ──
  (function () {
    if (window.location.search.indexOf('variant=') !== -1) return;

    function clearSelections() {
      document.querySelectorAll(
        'input[type="radio"][name*="-"][data-fieldset-index], ' +
        '.variant-option__button-label input[type="radio"]'
      ).forEach(function(radio) {
        radio.checked = false;
        radio.dataset.currentChecked = 'false';
        radio.dataset.previousChecked = 'false';
      });

      document.querySelectorAll(
        '.variant-option__button-label--selected, ' +
        '[class*="variant"][class*="selected"], ' +
        '[aria-checked="true"]'
      ).forEach(function(el) {
        el.classList.remove('variant-option__button-label--selected');
        el.setAttribute('aria-checked', 'false');
      });
    }

    clearSelections();
    setTimeout(clearSelections, 100);
    setTimeout(clearSelections, 400);
  })();
  </script>

{% endif %}

{% schema %}
{
  "name": "t:names.custom_liquid",
  "tag": null,
  "settings": [
    {
      "type": "liquid",
      "id": "custom_liquid",
      "label": "t:settings.custom_liquid",
      "info": "t:info.custom_liquid"
    }
  ],
  "presets": [
    {
      "name": "t:names.custom_liquid",
      "category": "t:categories.custom"
    }
  ]
}
{% endschema %}
