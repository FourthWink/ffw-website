<div class="ffwinks-cart-router" style="min-height: 60vh; display: flex; align-items: center; justify-content: center;">
  <p style="font-family: var(--font-heading-family); font-size: 10px;  ">
    Loading your cart...
  </p>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    function openRouterCart() {
      if (!window.ffwinksOpenCart) return false;
      window.ffwinksOpenCart();
      var cartOverlay = document.getElementById('ffwinks-cart-overlay');
      if (cartOverlay) {
        var observer = new MutationObserver(function (mutations) {
          mutations.forEach(function (mutation) {
            if (mutation.attributeName === 'aria-hidden') {
              if (cartOverlay.getAttribute('aria-hidden') === 'true') {
                window.location.href = '/';
              }
            }
          });
        });
        observer.observe(cartOverlay, { attributes: true });
      }
      return true;
    }
    if (openRouterCart()) return;
    setTimeout(function () {
      if (openRouterCart()) return;
      window.location.href = '/';
    }, 50);
  });
</script>
