{% comment %}
  Fourth Wink cart overlay section.

  This file still includes the standard Custom Liquid wrapper at the top, but
  the rest of the section is brand-specific cart overlay UI. It owns the legacy
  #cart-overlay drawer, its floating checkout star, and the click handlers that
  bridge custom Add to Cart controls into Shopify's cart APIs.

  The product template also uses this section type only to render the floating
  ATC snippet. That instance skips the overlay below so product pages do not
  mount duplicate cart drawers with the same IDs.
{% endcomment %}

{%- liquid
  assign is_product_floating_atc_section = false
  if template.name == 'product' and section.settings.custom_liquid contains 'floating-atc'
    assign is_product_floating_atc_section = true
  endif
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} spacing-style {% if section.settings.color_scheme != blank %}color-{{ section.settings.color_scheme }}{% endif %} {% if section.settings.fixed_bottom %}fixed-bottom-section{% endif %}"
  style="{% render 'spacing-padding', settings: section.settings %}"
>
  {{ section.settings.custom_liquid }}
</div>

{% unless is_product_floating_atc_section %}
{% render 'ffw-cart-overlay-markup' %}
{% render 'ffw-cart-overlay-styles' %}

<script>
(function () {
  try {
    // Cache the overlay nodes once. Most helpers below are defensive because
    // this section can be rendered on templates where only part of the cart UI
    // is present.
    var overlay = document.getElementById('cart-overlay');
    var backdrop = document.getElementById('cart-backdrop');
    var desktopFloatingWrapper = document.getElementById('cart-checkout-wrapper-desktop');
    
    // Desktop overlay controls and render targets.
    var closeBtnDesktop = document.getElementById('cart-close-desktop');
    var itemsWrapDesktop = document.getElementById('cart-items-desktop');
    var subtotalDesktop = document.getElementById('cart-subtotal-desktop');
    var taxNoteDesktop = document.querySelector('.cart-overlay__tax-note');
    
    // Mobile overlay controls and render targets.
    var closeBtnMobile = document.getElementById('cart-close-mobile');
    var itemsWrapMobile = document.getElementById('cart-items-mobile');
    var subtotalMobile = document.getElementById('cart-subtotal-mobile');
    var taxNoteMobile = document.getElementById('cart-overlay-tax-note-mobile');
    var checkoutWrapMobile = document.getElementById('cart-checkout-wrapper-mobile');
    var closeBtnMobileOverlay = document.getElementById('cart-close-mobile-overlay');

    // Keeps the last rendered cart item scrollable past the fixed checkout UI.
    function updateDynamicPadding() {
      var isMobile = window.innerWidth <= 749;
      var container = isMobile ? document.querySelector('.mobile-scrollable-area') : document.getElementById('cart-items-desktop');
      
      if (!container) return;
      var rows = Array.from(container.querySelectorAll(isMobile ? '.ffwinks-soul-row' : '.cart-item'));
      if (rows.length === 0) return;

      var footer = isMobile ? null : document.querySelector('.cart-overlay__footer');
      var footerHeight = footer ? footer.getBoundingClientRect().height : 0;
      
      // Pad the container enough so the last item can always reach the middle of the screen
      var padding = (window.innerHeight * 0.6) + footerHeight;
      document.documentElement.style.setProperty('--cart-items-padding-bottom', padding + 'px');
    }

    // Repositions the checkout star so it floats until it meets the last item.
    function ffwinksUpdateCartStar() {
      var isMobile = window.innerWidth <= 749;

      if (isMobile) {
        var mobileStar = document.getElementById('cart-checkout-wrapper-mobile');
        var mobileContainer = document.querySelector('.mobile-scrollable-area');
        var inactiveDesktopStar = document.getElementById('cart-checkout-wrapper-desktop');

        if (inactiveDesktopStar) inactiveDesktopStar.style.setProperty('display', 'none', 'important');
        if (!mobileStar || !mobileContainer) return;

        var mobileRows = Array.from(mobileContainer.querySelectorAll('.ffwinks-soul-row'));
        mobileContainer.style.overflowY = (mobileRows.length <= 1) ? 'hidden' : '';

        if (mobileRows.length === 0) {
          mobileStar.style.setProperty('display', 'none', 'important');
          return;
        }

        mobileStar.style.setProperty('display', 'flex', 'important');

        var lastRow = mobileRows[mobileRows.length - 1];
        var lastImg = lastRow.querySelector('.ffwinks-soul-img-box') || lastRow;
        var lastRect = lastImg.getBoundingClientRect();

        // Flawless locking math: Float at 50vh, attach when the box scrolls past 50vh.
        var fixedY = window.innerHeight * 0.5;
        var targetY = Math.min(fixedY, lastRect.bottom);

        mobileStar.style.setProperty('position', 'fixed', 'important');
        mobileStar.style.setProperty('z-index', '505', 'important');
        mobileStar.style.setProperty('top', targetY + 'px', 'important');
        mobileStar.style.removeProperty('left'); // Let CSS handle X-axis
        mobileStar.style.setProperty('transform', 'translate(-50%, -50%)', 'important');
        return;
      }

      var star = document.getElementById('cart-checkout-wrapper-desktop');
      var container = document.getElementById('cart-items-desktop');
      var inactiveStar = document.getElementById('cart-checkout-wrapper-mobile');

      if (inactiveStar) inactiveStar.style.setProperty('display', 'none', 'important');
      if (!star || !container) return;

      var rows = Array.from(container.querySelectorAll('.cart-item'));
      container.style.overflowY = (rows.length <= 1) ? 'hidden' : '';

      if (rows.length === 0) {
        star.style.setProperty('display', 'none', 'important');
        return;
      }

      star.style.setProperty('display', 'block', 'important');

      var lastRow = rows[rows.length - 1];
      var lastImg = lastRow.querySelector('.cart-item__left') || lastRow;
      var lastRect = lastImg.getBoundingClientRect();

      var fixedY = window.innerHeight * 0.5;
      var targetY = Math.min(fixedY, lastRect.bottom);

      star.style.setProperty('position', 'fixed', 'important');
      star.style.setProperty('z-index', '505', 'important');
      star.style.setProperty('top', targetY + 'px', 'important');
      star.style.removeProperty('left'); // Ensures CSS straddles the 50vw line perfectly
      star.style.setProperty('transform', 'translate(-50%, -50%)', 'important');
    }

    var cartScrollTick = false;
    function onCartScroll() {
      if (!cartScrollTick) {
        window.requestAnimationFrame(function() {
          ffwinksUpdateCartStar();
          cartScrollTick = false;
        });
        cartScrollTick = true;
      }
    }
    
    var desktopScrollArea = document.getElementById('cart-items-desktop');
    var mobileScrollArea = document.querySelector('.mobile-scrollable-area');
    
    if (desktopScrollArea) desktopScrollArea.addEventListener('scroll', onCartScroll);
    if (mobileScrollArea) mobileScrollArea.addEventListener('scroll', onCartScroll);
    function handleCartViewportChange() {
      updateDynamicPadding();
      onCartScroll();
    }

    window.addEventListener('resize', handleCartViewportChange);
    if (window.visualViewport) {
      window.visualViewport.addEventListener('resize', handleCartViewportChange);
    }

    // Preorder-only carts use different checkout copy because shipping is not
    // collected at deposit time.
    function updateCartTaxNote(cart) {
      var isPreorder = cart.items && cart.items.every(function(item) {
        var p = (item && item.properties) || {};
        return p._preorder === true || String(p._preorder).toLowerCase() === 'true' || String(p['Order type']).toLowerCase() === 'preorder';
      });
      var noteText = isPreorder ? 'Taxes calculated at checkout.' : 'Shipping and taxes calculated at checkout';
      if (taxNoteDesktop) taxNoteDesktop.textContent = noteText;
      if (taxNoteMobile) taxNoteMobile.textContent = noteText;
    }

    function fetchOverlayCartJson() {
      return fetch('/cart.js').then(function(r) { return r.json(); });
    }

    if (overlay._cartBound) return;
    overlay._cartBound = true;

    // Keep the native theme cart badge in sync when this custom drawer handles
    // cart mutations outside Shopify's default cart components.
    function updateCartBubble(totalQty) {
      document.dispatchEvent(new CustomEvent('cart:update', { bubbles: true, detail: { data: { itemCount: totalQty } } }));
      document.querySelectorAll('[ref="cartBubbleCount"]').forEach(function(el) {
        el.textContent = totalQty > 0 ? String(totalQty) : '';
        el.classList.toggle('hidden', totalQty === 0);
      });
      document.querySelectorAll('[ref="cartBubble"]').forEach(function(el) {
        el.classList.toggle('visually-hidden', totalQty === 0);
      });
    }

    function mountDesktopFloatingWrapper() {
      if (!desktopFloatingWrapper) return;
      if (desktopFloatingWrapper.parentNode !== document.body) {
        document.body.appendChild(desktopFloatingWrapper);
      }
    }

    // Move the overlay to <body> before opening so fixed positioning is not
    // affected by section wrappers or Shopify view-transition containers.
    function openCart() {
      mountDesktopFloatingWrapper();
      if (overlay.parentNode !== document.body) {
        document.body.appendChild(overlay);
      }
      overlay.classList.add('is-open');
      document.body.classList.add('cart-overlay-open');
      fetchCart();
    }

    function closeCart() {
      overlay.classList.add('is-closing');
      setTimeout(function () {
        overlay.classList.remove('is-open', 'is-closing');
        document.body.classList.remove('cart-overlay-open');
      }, 260);
    }

    function fetchCart() {
      if (itemsWrapDesktop) itemsWrapDesktop.innerHTML = '<div class="cart-overlay__loading">Loading cart…</div>';
      if (itemsWrapMobile) itemsWrapMobile.innerHTML = '<div class="ffwinks-empty-msg">Loading cart…</div>';
      
      fetchOverlayCartJson().then(renderCart).catch(function () {
        if (itemsWrapDesktop) itemsWrapDesktop.innerHTML = '<div class="cart-overlay__loading">Unable to load cart.</div>';
        if (itemsWrapMobile) itemsWrapMobile.innerHTML = '<div class="ffwinks-empty-msg">Unable to load cart.</div>';
      });
    }

    function formatMoney(cents) {
      return (cents / 100).toLocaleString('en-US', {
        style: 'currency',
        currency: (window.Shopify && window.Shopify.currency && window.Shopify.currency.active) || 'EUR'
      }).replace('.00', '');
    }

    // Renders both desktop drawer rows and mobile "soul" rows from /cart.js.
    // Keep the two HTML strings aligned when changing quantity or variant UI.
    function renderCart(cart) {
      var priceStr = formatMoney(cart.total_price);
      if (subtotalDesktop) subtotalDesktop.textContent = priceStr;
      if (subtotalMobile) subtotalMobile.textContent = priceStr;
      
      updateCartBubble(cart.item_count);
      updateCartTaxNote(cart);

      if (!cart.items || cart.items.length === 0) {
        if (itemsWrapDesktop) itemsWrapDesktop.innerHTML = '<div class="cart-overlay__loading">Your cart is empty.</div>';
        if (itemsWrapMobile) itemsWrapMobile.innerHTML = '<div class="ffwinks-empty-msg">Your cart is empty.</div>';
        if (checkoutWrapMobile) checkoutWrapMobile.style.display = 'none';
        var desktopStar = document.getElementById('cart-checkout-wrapper-desktop');
        if (desktopStar) desktopStar.style.display = 'none';
        
        setTimeout(ffwinksUpdateCartStar, 50);
        return;
      }
      
      if (checkoutWrapMobile) checkoutWrapMobile.style.display = 'flex';
      var desktopStar = document.getElementById('cart-checkout-wrapper-desktop');
      if (desktopStar) desktopStar.style.display = 'block';

      var desktopHtml = '';
      var mobileHtml = '';

      cart.items.forEach(function(item, i) {
        var itemUrl = item.url || item.product_url || '#';
        
        // DESKTOP
        var desktopVariantHtml = '';
        if (item.variant_title && item.variant_title !== 'Default Title') {
          var desktopVariants = item.variant_title.split(' / ');
          if (desktopVariants[0]) desktopVariantHtml += '<div class="cart-item__variant-row"><span class="cart-item__variant-label">Size</span><span>' + desktopVariants[0].trim() + '</span></div>';
          if (desktopVariants[1]) desktopVariantHtml += '<div class="cart-item__variant-row"><span class="cart-item__variant-label">Color</span><span>' + desktopVariants[1].trim() + '</span></div>';
        }

        desktopHtml += '<div class="cart-item desktop-item" style="animation-delay:' + (i * 0.05) + 's" data-key="' + item.key + '">'
          + '<button class="cart-item__remove-btn-desktop cart-item__qty-btn" data-action="remove" data-key="' + item.key + '" aria-label="Remove">x</button>'
          + '<a class="cart-item__left" href="' + itemUrl + '" aria-label="View ' + item.product_title + '">'
          + (item.image ? '<img src="' + item.image + '" alt="' + item.product_title + '" loading="lazy">' : '')
          + '</a>'
          + '<div class="cart-item__right">'
          +   '<div class="cart-item__row">'
          +     '<span class="cart-item__title">' + item.product_title + '</span>'
          +     '<span class="cart-item__price">' + formatMoney(item.final_line_price) + '</span>'
          +   '</div>'
          +   desktopVariantHtml
          +   '<div class="cart-item__qty-container">'
          +     '<span class="cart-item__qty-label">Quantity</span>'
          +     '<div class="cart-item__qty">'
          +       '<button class="cart-item__qty-btn" data-action="decrease" data-key="' + item.key + '" aria-label="Decrease">−</button>'
          +       '<span class="cart-item__qty-num">' + item.quantity + '</span>'
          +       '<button class="cart-item__qty-btn" data-action="increase" data-key="' + item.key + '" aria-label="Increase">+</button>'
          +     '</div>'
          +   '</div>'
          + '</div>'
          + '</div>';

        // MOBILE
        var mobileVariantHtml = '';
        if (item.variant_title && item.variant_title !== 'Default Title') {
          var mobileVariants = item.variant_title.split(' / ');
          var v1 = mobileVariants[0] ? mobileVariants[0].trim() : '';
          var v2 = mobileVariants[1] ? mobileVariants[1].trim() : '';
          
          var isV2Size = ['XS','S','M','L','XL','XXL'].includes(v2.toUpperCase());
          if (isV2Size) {
             mobileVariantHtml += '<div class="ffwinks-soul-label">Size</div><div class="ffwinks-soul-value">' + v2 + '</div>';
             mobileVariantHtml += '<div class="ffwinks-soul-label">Color</div><div class="ffwinks-soul-value">' + v1 + '</div>';
          } else {
             if (v1) mobileVariantHtml += '<div class="ffwinks-soul-label">Size</div><div class="ffwinks-soul-value">' + v1 + '</div>';
             if (v2) mobileVariantHtml += '<div class="ffwinks-soul-label">Color</div><div class="ffwinks-soul-value">' + v2 + '</div>';
          }
        }

        mobileHtml += '<div class="ffwinks-soul-row mobile-item" style="animation-delay:' + (i * 0.05) + 's" data-key="' + item.key + '">'
          + '<button class="ffwinks-soul-remove cart-item__qty-btn" data-action="remove" data-key="' + item.key + '" aria-label="Remove">x</button>'
          + '<a class="ffwinks-soul-img-box" href="' + itemUrl + '" aria-label="View ' + item.product_title + '">'
          + (item.image ? '<img src="' + item.image + '" alt="' + item.product_title + '" loading="lazy">' : '')
          + '</a>'
          + '<div class="ffwinks-soul-details-box">'
          +   '<div class="ffwinks-soul-grid">'
          +     '<div class="ffwinks-soul-label">Product</div>'
          +     '<div class="ffwinks-soul-value">' + item.product_title + '</div>'
          +     '<div class="ffwinks-soul-label">Price</div>'
          +     '<div class="ffwinks-soul-value">' + formatMoney(item.final_line_price) + '</div>'
          +     mobileVariantHtml
          +     '<div class="ffwinks-soul-label">Quantity</div>'
          +     '<div class="ffwinks-soul-value">'
          +       '<div class="ffwinks-soul-qty">'
          +         '<button class="ffwinks-soul-qty__btn cart-item__qty-btn" data-action="decrease" data-key="' + item.key + '" aria-label="Decrease">−</button>'
          +         '<span class="cart-item__qty-num ffwinks-soul-qty__num">' + item.quantity + '</span>'
          +         '<button class="ffwinks-soul-qty__btn cart-item__qty-btn" data-action="increase" data-key="' + item.key + '" aria-label="Increase">+</button>'
          +       '</div>'
          +     '</div>'
          +   '</div>'
          + '</div>'
          + '</div>';
      });

      if (itemsWrapDesktop) itemsWrapDesktop.innerHTML = desktopHtml;
      if (itemsWrapMobile)  itemsWrapMobile.innerHTML = mobileHtml;

      setTimeout(function() {
        updateDynamicPadding();
        ffwinksUpdateCartStar();
      }, 50);
    }

    function applyQtyOptimistically(key, delta) {
      var rows = [];
      if(itemsWrapDesktop) {
          var dRow = itemsWrapDesktop.querySelector('[data-key="' + key + '"]');
          if(dRow) rows.push(dRow);
      }
      if(itemsWrapMobile) {
          var mRow = itemsWrapMobile.querySelector('[data-key="' + key + '"]');
          if(mRow) rows.push(mRow);
      }
      
      var current = 1;
      if (rows.length > 0) {
        var qtyEl = rows[0].querySelector('.cart-item__qty-num, .ffwinks-soul-qty__num');
        if (qtyEl) current = parseInt(qtyEl.textContent, 10);
      }

      var newQty = delta === -999 ? 0 : Math.max(0, current + delta);

      rows.forEach(function(row) {
        var qtyEl = row.querySelector('.cart-item__qty-num, .ffwinks-soul-qty__num');
        if (qtyEl) qtyEl.textContent = newQty;
        if (newQty === 0) row.style.opacity = '0.4';
      });
      return newQty;
    }

    function updateQty(key, delta) {
      var newQty = applyQtyOptimistically(key, delta);
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: key, quantity: newQty })
      })
      .then(function(r) { return r.json(); })
      .then(function(cart) { renderCart(cart); })
      .catch(function() {
        fetchOverlayCartJson().then(function (cart) { renderCart(cart); });
      });
    }

    // One delegated listener owns cart quantity actions, cart triggers, checkout
    // cleanup, and the floating Add to Cart button. Splitting this should be a
    // deliberate refactor because event order matters.
    document.addEventListener('click', function (e) {
      var actionBtn = e.target.closest('.cart-item__qty-btn, .ffwinks-soul-qty__btn, .cart-item__remove-btn-desktop, .ffwinks-soul-remove');
      
      if (actionBtn && overlay.contains(actionBtn)) {
        var action = actionBtn.dataset.action;
        var key = actionBtn.dataset.key;
        
        if (action === 'remove') {
          updateQty(key, -999);
        } else {
          updateQty(key, action === 'increase' ? 1 : -1);
        }
        return;
      }

      var trigger = e.target.closest('[data-cart-trigger], .cart-trigger, #cart-trigger, [href="#cart"], [data-open-cart], a[href*="/cart"]');
      if (trigger && !overlay.contains(trigger) && !trigger.closest('form')) {
        e.preventDefault();
        openCart();
        return;
      }

      var checkoutLink = e.target.closest('a[href*="/checkout"]');
      if (checkoutLink && (overlay.contains(checkoutLink) || checkoutLink.closest('.cart-overlay__floating-wrapper'))) {
        closeCart();
      }

      var atcBtn = e.target.closest('.floating-atc-btn');
      if (atcBtn && !atcBtn.disabled) {
        e.preventDefault();
        e.stopImmediatePropagation();
        var rootUrl = window.Shopify && window.Shopify.routes ? window.Shopify.routes.root : '/';
        var variantId = new URLSearchParams(window.location.search).get('variant');
        if (!variantId) {
          var formInput = document.querySelector('form[action*="/cart/add"] [name="id"], select[name="id"], input[name="id"]');
          if (formInput && formInput.value) {
            variantId = formInput.value;
          }
        }

        if (!variantId) {
          // A missing variant means the custom picker has no complete selection.
          // Nudge the picker instead of submitting an invalid add-to-cart request.
          var picker = document.querySelector('[class*="variant-picker"]');
          if (picker) {
            picker.style.transition = 'opacity 0.15s';
            picker.style.opacity = '0.4';
            setTimeout(function() { picker.style.opacity = '1'; }, 150);
            setTimeout(function() { picker.style.opacity = '0.4'; }, 300);
            setTimeout(function() { picker.style.opacity = '1'; }, 450);
          }
          
          var labelEl = atcBtn.querySelector('.floating-atc-text') || atcBtn.querySelector('.ffwinks-img-label') || atcBtn;
          var origText = labelEl.textContent;
          var origColor = labelEl.style.color;
          var origWeight = labelEl.style.fontWeight;
          
          labelEl.textContent = 'Pick size/color';
          labelEl.style.color = '#ff4d4d'; 
          labelEl.style.fontWeight = '600';
          
          setTimeout(function() {
            labelEl.textContent = origText;
            labelEl.style.color = origColor;
            labelEl.style.fontWeight = origWeight;
          }, 1500);
          return;
        }

        atcBtn.disabled = true;
        document.body.classList.add('ffwinks-adding');
        function finishAdd(success) {
          atcBtn.disabled = false;
          document.body.classList.remove('ffwinks-adding');
          if (success) {
            if (window.innerWidth <= 749) {
              var headerCartIcon = document.querySelector('.header__icon--cart, a[href*="/cart"]');
              if (headerCartIcon) {
                headerCartIcon.click();
              } else {
                window.location.href = '/cart';
              }
            } else {
              openCart();
            }
          }
        }

        fetch(rootUrl + 'cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: [{ id: parseInt(variantId, 10), quantity: 1 }] })
        })
        .then(function(r) {
          if (!r.ok) throw new Error('add failed');
          return r.json();
        })
        .then(function() { finishAdd(true); })
        .catch(function(err) {
          console.error('ATC error:', err);
          finishAdd(false);
        });
        return;
      }
    });

    if (closeBtnDesktop) closeBtnDesktop.addEventListener('click', closeCart);
    if (closeBtnMobile) closeBtnMobile.addEventListener('click', closeCart);
    if (backdrop) backdrop.addEventListener('click', closeCart);
    if (closeBtnMobileOverlay) closeBtnMobileOverlay.addEventListener('click', closeCart);
    mountDesktopFloatingWrapper();
    
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && overlay.classList.contains('is-open')) closeCart();
    });
    window.CartOverlay = { open: openCart, close: closeCart };

  } catch (err) {
    console.error("Cart Overlay Error:", err);
  }
})();

// Cleaned up unified Variant Auto-Selector
document.addEventListener('DOMContentLoaded', function () {
  try {
    function autoSelectVariants() {
      const variantSelects = document.querySelectorAll('select[name="id"], .product-form__input select');
      variantSelects.forEach(select => {
        if (select.options.length === 1) {
          select.selectedIndex = 0;
          select.dispatchEvent(new Event('change', { bubbles: true }));
        }
      });

      const optionSets = document.querySelectorAll('.product-form__input fieldset, .variant-picker__fieldset');
      optionSets.forEach(fieldset => {
        const radios = fieldset.querySelectorAll('input[type="radio"]');
        if (radios.length === 1) {
          radios[0].checked = true;
          radios[0].dispatchEvent(new Event('change', { bubbles: true }));
        }
      });

      const masterInput = document.querySelector('form[action*="/cart/add"] input[name="id"]');
      if (masterInput && !masterInput.value) {
        const firstVariantOption = document.querySelector('form[action*="/cart/add"] select[name="id"] option');
        if (firstVariantOption) {
          masterInput.value = firstVariantOption.value;
        }
      }
    }

    function unlockAddToCart() {
      const atcButtons = document.querySelectorAll('.floating-atc-btn, .product-form__submit, [name="add"]');
      atcButtons.forEach(button => {
        button.removeAttribute('disabled');
        button.classList.remove('disabled', 'is-disabled');
        button.style.pointerEvents = 'auto';
      });
    }

    autoSelectVariants();
    unlockAddToCart();

    const observer = new MutationObserver(function() {
      unlockAddToCart();
    });
    
    observer.observe(document.body, { childList: true, subtree: true });
    window.addEventListener('beforeunload', () => observer.disconnect());
  } catch (e) {
    console.error("Variant Auto-Selector Error:", e);
  }
});
</script>
{% endunless %}

{% schema %}
{
  "name": "t:names.custom_liquid",
  "settings": [
    {
      "type": "liquid",
      "id": "custom_liquid",
      "label": "t:settings.custom_liquid",
      "info": "t:info.custom_liquid"
    },
    {
      "type": "checkbox",
      "id": "fixed_bottom",
      "label": "Fix to bottom of screen",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        { "value": "page-width",  "label": "t:options.page" },
        { "value": "full-width",  "label": "t:options.full" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "t:content.padding"
