        "custom_liquid": "<style>\n  /* MOBILE ONLY - max-width: 768px */\n  @media (max-width: 768px) {\n    /* Main footer container - vertical stack */\n    .ff-footer {\n      display: flex !important;\n      flex-direction: column !important;\n      align-items: flex-start !important;\n      gap: 18px !important;\n      width: 100% !important;\n    }\n\n    /* 1. Brand paragraph + name - at top */\n    .ff-middle {\n      order: 1 !important;\n      width: 100% !important;\n      max-width: 100% !important;\n      text-align: left !important;\n      margin: 0 !important;\n      padding: 0 !important;\n    }\n\n    .ff-middle p {\n      margin: 0 0 8px 0 !important;\n      font-size: 11px !important;\n      line-height: 1.5 !important;\n      color: #555555 !important;\n    }\n\n    .ff-middle .brand-name {\n      font-size: 11px !important;\n     color: #555555 !important;\n      margin: 0 !important;\n    }\n\n    /* 2. Links - each on own line, left-aligned */\n    .ff-left {\n      order: 2 !important;\n      width: 100% !important;\n      display: flex !important;\n      flex-direction: column !important;\n      align-items: flex-start !important;\n      gap: 8px !important;\n      margin: 0 !important;\n      padding: 0 !important;\n    }\n\n    .ff-left a {\n      display: block !important;\n      font-size: 11px !important;\n      color: #555555 !important;\n      text-decoration: none !important;\n      line-height: 1.5 !important;\n      margin: 0 !important;\n      padding: 0 !important;\n    }\n\n    .ff-left a:hover {\n      color: #333333 !important;\n    }\n\n    /* 3. Social icons - single row, left-aligned */\n    .ff-icons {\n      order: 3 !important;\n      width: 100% !important;\n      display: flex !important;\n      flex-direction: row !important;\n      align-items: center !important;\n      gap: 16px !important;\n      margin: 0 !important;\n      padding: 0 !important;\n    }\n\n    .ff-icons a {\n      display: inline-flex !important;\n      align-items: center !important;\n      justify-content: center !important;\n      width: 22px !important;\n      height: 22px !important;\n      color: #555555 !important;\n      text-decoration: none !important;\n      margin: 0 !important;\n      padding: 0 !important;\n    }\n\n    .ff-icons a:hover {\n      color: #333333 !important;\n    }\n\n    .ff-icons svg {\n      width: 22px !important;\n      height: 22px !important;\n    }\n\n    /* 4. Email input - full width at bottom */\n    .ff-email {\n      order: 4 !important;\n      width: 100% !important;\n      display: flex !important;\n      flex-direction: column !important;\n      align-items: flex-start !important;\n      margin: 0 !important;\n      padding: 0 !important;\n      margin-top: 8px !important;\n    }\n\n    .ff-email input {\n      width: 100% !important;\n      max-width: 100% !important;\n      padding: 10px 0 !important;\n      font-size: 11px !important;\n      color: #555555 !important;\n      background: transparent !important;\n      border: none !important;\n      border-bottom: 1px solid #dddddd !important;\n      outline: none !important;\n      font-family: inherit !important;\n      box-sizing: border-box !important;\n    }\n\n    .ff-email input::placeholder {\n      color: #999999 !important;\n    }\n\n    .ff-email input:focus {\n      border-bottom-color: #555555 !important;\n      box-shadow: none !important;\n    }\n\n    .ff-email input:hover {\n      border-bottom-color: #777777 !important;\n    }\n  }\n</style>",
