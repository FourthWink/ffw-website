/* ┌─────────────────────────────────────────────────────────────────┐
   │ ► SECTION: CHECKOUT TRANSITION                                  │
   └─────────────────────────────────────────────────────────────────┘ */

#ffw-checkout-transition {
  position: fixed;
  inset: 0;
  width: 100vw;
  height: 100dvh;
  background-color: #ffffff;
  z-index: 2147483647;

  display: block;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;

  transition: opacity 0.2s ease, visibility 0s 0.2s;
}

#ffw-checkout-transition.is-active {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  transition: opacity 0.2s ease, visibility 0s 0s;
}

/* Base positioning (Desktop/Tablet) */
.ffw-lips-transition-icon {
  width: 260px;
  height: auto;
  position: absolute;
  /* Adjust these values to place it exactly where you want on larger screens */
  top: 160px;
  left: 300px;
  
  transform: rotate(-22deg);
  transform-origin: center center;
  opacity: 0;
  animation: none;
}

/* Mobile positioning override */
@media screen and (max-width: 749px) {
  .ffw-lips-transition-icon {
    /* Adjust these values to place it exactly where you want on mobile */
    top: 25%;
    left: 50px;
    
    /* Optional: Shrink the lips a bit for mobile so they fit better */
    width: 180px; 
  }
}

/* Trigger the animation */
#ffw-checkout-transition.is-active .ffw-lips-transition-icon {
  animation: ffw-lips-fade-once 0.9s ease-in-out 1 forwards;
}

/* Cleaned up keyframes: only animates opacity and scale now */
@keyframes ffw-lips-fade-once {
  0% {
    opacity: 0;
    transform: rotate(-22deg) scale(0.96);
  }
  35% {
    opacity: 1;
    transform: rotate(-22deg) scale(1);
  }
  65% {
    opacity: 1;
    transform: rotate(-22deg) scale(1);
  }
  100% {
    opacity: 0;
    transform: rotate(-22deg) scale(0.96);
  }
}
<script>
(function () {

  // ============================================================
  // WAIT FOR DOM
  // ============================================================
  function ready(fn) {
    if (document.readyState !== 'loading') { fn(); }
    else { document.addEventListener('DOMContentLoaded', fn); }
  }

  ready(function () {

    var transitionScreen = document.getElementById('ffw-checkout-transition');


    // ============================================================
    // HELPER: is this click targeting checkout?
    // ============================================================
    function isCheckoutTarget(el) {
      return !!(
        el.closest('.ffwinks-checkout-link-wrap')  ||
        el.closest('.ffwinks-soul-action-bottom')  ||
        el.closest('a[href*="checkout"]')          ||
        el.closest('button[name="checkout"]')      ||
        el.closest('input[name="checkout"]')
      );
    }

    // ============================================================
    // HELPER: is this click targeting the cart icon (NOT checkout)?
    // ============================================================
    function isCartIconTarget(el) {
      return !!(
        el.closest('.action__cart')                           ||
        el.closest('[data-ffwinks-cart]')                     ||
        el.closest('a[href="/cart"]:not([href*="checkout"])')
      );
    }


    // ============================================================
    // CHECKOUT TRANSITION
    // Visual-only lips animation, then redirect to checkout.
    // ============================================================
    function executeTransition(e, targetUrl) {
      e.preventDefault();
      e.stopImmediatePropagation();

      // 1. Show lips animation
      if (transitionScreen) {
        transitionScreen.classList.remove('is-active');
        void transitionScreen.offsetWidth; // force repaint
        transitionScreen.classList.add('is-active');
      }

      // 2. Navigate after animation
      setTimeout(function () {
        window.location.href = targetUrl;
      }, 2000);
    }


    // ============================================================
    // CLICK LISTENER — checkout targets only
    // isCartIconTarget guard stops cart-icon clicks from
    // accidentally hitting the checkout path
    // ============================================================
    document.addEventListener('click', function (e) {
      if (isCartIconTarget(e.target)) return;
      if (!isCheckoutTarget(e.target)) return;

      var url = '/checkout';
      var parentLink = e.target.closest('a');
      if (parentLink && parentLink.href) url = parentLink.href;

      executeTransition(e, url);

    }, true);


    // ============================================================
    // FORM SUBMIT LISTENER
    // ============================================================
    document.addEventListener('submit', function (e) {
      var form = e.target;
      if (!form || !form.action) return;

      // — Add to cart: silent fetch, then open overlay via custom event
      if (form.action.includes('/cart/add')) {
        e.preventDefault();
        e.stopImmediatePropagation();

        var submitBtn     = form.querySelector('[type="submit"]');
        var originalHTML  = submitBtn ? submitBtn.innerHTML : '';
        if (submitBtn) submitBtn.innerHTML = 'Adding...';

        fetch(window.Shopify.routes.root + 'cart/add.js', {
          method: 'POST',
          body: new FormData(form)
        })
        .then(function (r) { return r.json(); })
        .then(function () {
          if (submitBtn) submitBtn.innerHTML = originalHTML;
          // Fire custom event — keeps this 100% separate from checkout path
          document.dispatchEvent(new CustomEvent('ffwinks:open-cart'));
        })
        .catch(function (err) {
          console.error('FFWinks — cart/add error:', err);
          if (submitBtn) submitBtn.innerHTML = originalHTML;
        });

        return;
      }

      // — Checkout form submission
      if (form.action.includes('/cart') || form.action.includes('/checkout')) {
        executeTransition(e, '/checkout');
      }

    }, true);


    // ============================================================
    // OPEN CART OVERLAY
    // Triggered by 'ffwinks:open-cart' custom event only —
    // completely isolated from the checkout click path so a
    // programmatic cart open can never trigger the checkout transition
    // ============================================================
    document.addEventListener('ffwinks:open-cart', function () {
      var cartOverlay = document.getElementById('ffwinks-cart-overlay');
      if (cartOverlay) {
        cartOverlay.classList.add('ffwinks-fullscreen--open');
        document.body.classList.add('ffwinks-open');
        return;
      }
      // Fallback: direct link click
      var headerCartLink = document.querySelector('.action__cart, a[href="/cart"]');
      if (headerCartLink) headerCartLink.click();
    });

  }); // end ready()

})();
</script>


/* ==========================================================
   FORCE GPU RENDERING FOR HOME PAGE STICKY STAR
   (Prevents scroll jitter when wishlist DOM gets heavy)
========================================================== */
