<style>
  /* Force-hide the slow, ugly native Shopify cart drawers and popups */
  cart-drawer, cart-notification, #cart-notification { 
    display: none !important; 
  }
</style>

<script>
  // Listen for ANY "Add to Cart" form submission on the entire website
  document.addEventListener('submit', function(e) {
    const form = e.target;
    
    // Check if the form is an Add to Cart form
    if (form.action && form.action.includes('/cart/add')) {
      e.preventDefault(); // Stop the page from reloading
      e.stopImmediatePropagation(); // KILLS the slow native theme JavaScript!
      
      const submitBtn = form.querySelector('[type="submit"]');
      const originalText = submitBtn ? submitBtn.innerHTML : '';
      
      // Optional: change button text to a quick loading state
      if (submitBtn) submitBtn.innerHTML = 'Adding...';

      // Silently and quickly add the item to the cart in the background
      fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        body: new FormData(form)
      })
      .then(response => response.json())
      .then(() => {
        if (submitBtn) submitBtn.innerHTML = originalText;
        
        // Instantly trigger our custom FFWinks cart from the header!
        const headerCartLink = document.querySelector('a[href*="/cart"]');
        if (headerCartLink) {
          headerCartLink.click(); 
        }
      })
      .catch(err => {
        console.error('Error adding to cart:', err);
        if (submitBtn) submitBtn.innerHTML = originalText;
      });
    }
  }, true); // The "true" ensures our code runs BEFORE the native Shopify theme code!
</script>
