  /* Typography for the letter "x" */
  color: #000;
  font-family: 'Montserrat', Arial, sans-serif !important;
  font-size: 10px;
  font-weight: 400;
  line-height: 1;
  padding-bottom: 2px; /* Slight nudge to visually center the lowercase x */
}


@media screen and (min-width: 750px) {
  .ffwinks-cart__close-btn.mobile-only {
    display: none !important;
  }
}
{% endstylesheet %}

